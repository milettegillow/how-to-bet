---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="An interactive explainer on the Kelly Criterion and gambler's ruin." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/betting.png" />
    <link rel="apple-touch-icon" href="/betting.png" />
    <meta property="og:title" content="How to bet (and win)" />
    <meta property="og:description" content="An interactive explainer on the Kelly Criterion and gambler's ruin." />
    <meta property="og:image" content="https://betting.milettegillow.com/og-image.png" />
    <meta property="og:url" content="https://betting.milettegillow.com" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="How to bet (and win)" />
    <meta name="twitter:description" content="An interactive explainer on the Kelly Criterion and gambler's ruin." />
    <meta name="twitter:image" content="https://betting.milettegillow.com/og-image.png" />
    <title>{title}</title>
  </head>
  <body class="bg-paper text-ink min-h-screen">
    <slot />
  </body>
</html>
