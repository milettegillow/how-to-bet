---
import Base from '../layouts/Base.astro';
import '../styles/global.css';

const sections = [
  { num: 4, id: 'kelly', title: 'Full Kelly vs half Kelly' },
  { num: 5, id: 'ruin', title: 'The warning: Gambler\'s Ruin' },
  { num: 6, id: 'beyond', title: 'Beyond the casino' },
];
---

<Base title="How to bet (and win)">
  <main class="px-4 sm:px-6">
    {/* ─── Header ─── */}
    <header class="max-w-prose mx-auto pt-20 pb-16 sm:pt-28 sm:pb-20">
      <h1 class="text-ink">How to bet (and win)</h1>
      <p class="mt-3 text-ink/60 italic" style="font-size: 1.05rem;">
        An interactive explainer on the Kelly Criterion and gambler's ruin.
      </p>
    </header>

    {/* ─── Section 1: The opening question ─── */}
    <section id="opening" class="max-w-prose mx-auto pb-20">
      <div class="flex items-start gap-4 mb-8">
        <img src="/chip-1.png" alt="" width="48" height="48" class="section-chip-img hidden sm:block" />
        <h2 class="mt-0" style="margin-top: 0;">
          <img src="/chip-1.png" alt="" width="32" height="32" class="section-chip-img inline sm:hidden mr-2 align-middle" />
          The opening question
        </h2>
      </div>

      <p class="text-body leading-relaxed">
        A coin pays even money<span
          class="tooltip-trigger"
          role="button"
          tabindex="0"
          aria-describedby="tooltip-even-money"
        >?<span class="tooltip-content" id="tooltip-even-money" role="tooltip"
          >If you bet £1 and win, you get £1 profit (plus your £1 back). If you lose, you're out £1.</span
        ></span> and lands heads 55% of the time. You have £1,000 in your account. How much do you bet?
      </p>

      {/* Slider + Button */}
      <div class="mt-10 mb-6" id="bet-controls">
        <label for="bet-slider" class="block mb-3 font-medium">Your bet</label>
        <input
          type="range"
          id="bet-slider"
          min="0"
          max="1000"
          step="10"
          value="0"
          aria-valuemin="0"
          aria-valuemax="1000"
          aria-valuenow="0"
          aria-valuetext="£0"
        />
        <div class="mt-3 text-center">
          <span class="font-mono text-lg" id="bet-readout">£0</span>
        </div>
      </div>

      <div class="text-center mt-8" id="bet-button-container">
        <button
          type="button"
          id="lock-bet"
          class="btn-primary"
        >
          Lock in my bet
        </button>
      </div>

      {/* Response panel */}
      <div class="response-panel mt-10" id="response-panel" aria-live="polite">
        <div class="border-l-2 border-card-red pl-5 py-2">
          <p id="response-text" class="mb-4"></p>
          <a
            href="#edge"
            class="text-sm text-gold no-underline hover:underline"
            style="text-decoration: none;"
            id="scroll-link"
          >scroll to see why ↓</a>
        </div>
      </div>
    </section>

    {/* ─── Section 2: Building intuition - edge ─── */}
    <section id="edge" class="max-w-prose mx-auto py-20 border-t border-ink/10">
      <div class="flex items-start gap-4 mb-8">
        <img src="/chip-2.png" alt="" width="48" height="48" class="section-chip-img hidden sm:block" />
        <h2 class="mt-0" style="margin-top: 0;">
          <img src="/chip-2.png" alt="" width="32" height="32" class="section-chip-img inline sm:hidden mr-2 align-middle" />
          Building intuition: edge
        </h2>
      </div>

      {/* ─── Part 1: Prose ─── */}
      <p>Every bet has two numbers: the probability you win, and how much you win if you do. Neither alone tells you whether the bet is worth taking. A 20% chance to win at 10:1 payout is a great bet; a 20% chance at 2:1 is a terrible one. We need a single number that combines both.</p>

      <p>That number is <strong>edge</strong>: how much money you expect to make, on average, for every £1 you stake.</p>

      <p>For a bet with win probability <em>p</em>, loss probability <em>q</em>&nbsp;=&nbsp;1&nbsp;−&nbsp;<em>p</em>, and net payout <em>b</em>&nbsp;:&nbsp;1 (meaning: stake £1, win £<em>b</em> profit if successful, lose your £1 if not), edge is:</p>

      <div class="formula">
        <strong>edge</strong> = <em>bp</em> − <em>q</em>
      </div>

      <p>Positive edge means you expect to make money. Zero edge means you break even on average. Negative edge means you expect to lose (which is why casinos exist).</p>

      <p>The <a href="https://en.wikipedia.org/wiki/Kelly_criterion" target="_blank" rel="noopener noreferrer">Kelly Criterion</a> takes edge and tells you what fraction of your bankroll to bet:</p>

      <div class="formula">
        <em>f</em> <sup>*</sup> = edge / <em>b</em>
      </div>

      <p>The formula captures the full picture: bet more when edge is large, and bet less when the payout <em>b</em> is large. A bigger <em>b</em> means rarer wins, so you can go through long losing runs before the payoff arrives. Kelly shrinks your bet to keep you solvent through those runs.</p>

      <p>Try it below. Drag the probability and payout sliders, and watch edge, fair odds, and the Kelly fraction update. Then click one of the reference chips below the calculator: each applies the parameters of a real-world bet so you can see how edge behaves across orders of magnitude.</p>

      {/* ─── Part 2: Edge calculator ─── */}
      <div class="mt-12 mb-8" id="edge-calculator">
        <div class="mb-8">
          <label for="p-slider" class="block mb-2 font-medium">Win probability (<em>p</em>)</label>
          <input
            type="range"
            id="p-slider"
            min="1"
            max="999"
            step="1"
            value="550"
            aria-valuemin="0.1"
            aria-valuemax="99.9"
            aria-valuenow="55.0"
            aria-valuetext="55.0%"
          />
          <div class="mt-2 text-center">
            <output for="p-slider" class="font-mono text-lg" id="p-readout">55.0%</output>
          </div>
        </div>

        <div class="mb-8">
          <label for="b-slider" class="block mb-2 font-medium">Payout (<em>b</em>&thinsp;:&thinsp;1)</label>
          <input
            type="range"
            id="b-slider"
            min="0"
            max="1000"
            step="1"
            value="137"
            aria-valuenow="1.0"
            aria-valuetext="1.0 : 1"
          />
          <div class="mt-2 text-center">
            <output for="b-slider" class="font-mono text-lg" id="b-readout">1.0 : 1</output>
          </div>
        </div>

        <div class="readout-grid">
          <div class="readout-card">
            <div class="readout-label">Edge (per £1 staked)</div>
            <output for="p-slider b-slider" class="readout-value block" id="edge-output">+£0.10</output>
          </div>
          <div class="readout-card">
            <div class="readout-label">Fair payout (<em>b</em> for zero edge)</div>
            <output for="p-slider" class="readout-value block" id="fair-output">0.82 : 1</output>
            <div class="readout-caption">the payout you'd need for a break-even bet at this probability</div>
          </div>
          <div class="readout-card">
            <div class="readout-label">What % of your money to bet</div>
            <output for="p-slider b-slider" class="readout-value block" id="kelly-output">10.00%</output>
            <div class="readout-caption" id="kelly-caption">the Kelly fraction, <em>f</em><sup class="text-[0.65em]">*</sup></div>
          </div>
          <div class="readout-card readout-card-hero">
            <div class="readout-label">Suggested bet on £1,000 bankroll</div>
            <output for="p-slider b-slider" class="readout-value block text-card-red font-bold" id="bet-s2-output">£100</output>
          </div>
        </div>
      </div>

      {/* ─── Part 3: Reference chips ─── */}
      <div class="preset-chips" id="preset-chips" role="group" aria-label="Reference bet presets">
        <button type="button" class="preset-chip" data-preset="lottery"
          aria-label="Lottery: UK National Lotto. p = 1 in 45 million, £2 ticket, £3.8m jackpot. One of the worst bets you'll encounter.">
          Lottery
          <span class="chip-tooltip">UK National Lotto. p&nbsp;=&nbsp;1 in 45&nbsp;million, £2 ticket, £3.8m jackpot. One of the worst bets you'll encounter.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="us-roulette"
          aria-label="US Roulette: American roulette, red/black. Two green zeros give the house a 5.26% edge, nearly double European roulette.">
          US Roulette
          <span class="chip-tooltip">American roulette, red/black. Two green zeros (0 and 00) give the house a 5.26% edge, nearly double European roulette.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="eu-roulette"
          aria-label="EU Roulette: European roulette, red/black. One green zero gives the house a 2.70% edge, half the house edge of the American version.">
          EU Roulette
          <span class="chip-tooltip">European roulette, red/black. One green zero gives the house a 2.70% edge, half the house edge of the American version.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="fair-coin"
          aria-label="Fair Coin: A fair coin paying even money. Zero edge. Kelly says don't play; the house can't beat you, but gambler's ruin eventually will.">
          Fair Coin
          <span class="chip-tooltip">A fair coin paying even money. Zero edge. Kelly says don't play; the house can't beat you, but gambler's ruin eventually will.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="biased-coin"
          aria-label="Biased Coin: The coin from the opening question. A small positive edge. Kelly: bet 10% of your bankroll.">
          Biased Coin
          <span class="chip-tooltip">The coin from the opening question. A small positive edge. Kelly: bet 10% of your bankroll.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="card-counter"
          aria-label="Card Counter: A skilled blackjack card counter's edge when the count is favourable. Thin edge, tiny bets, long grind.">
          Card Counter
          <span class="chip-tooltip">A skilled blackjack card counter's edge when the count is favourable. Thin edge, tiny bets, long grind.</span>
        </button>
        <button type="button" class="preset-chip" data-preset="vc"
          aria-label="Pre-seed VC: A pre-seed venture capital investment. Roughly 10% of investments return 20× or more; the rest go to zero. Large positive edge, but enormous variance.">
          Pre-seed VC
          <span class="chip-tooltip">A pre-seed venture capital investment. Roughly 10% of investments return 20× or more; the rest go to zero. Large positive edge, but enormous variance, which is why VCs diversify across 20–30 portfolio companies.</span>
        </button>
      </div>

      {/* ─── Part 4: Transition prose ─── */}
      <p class="mt-12">Notice how the pre-seed VC's fraction is only 5.5%, despite the enormous edge. Notice how even a 55/45 coin has you only betting 10%. The formula is conservative for a reason. The next section shows you why.</p>

      <div class="text-center mt-6">
        <a
          href="#simulator"
          class="text-sm text-gold"
          style="text-decoration: none;"
          id="scroll-to-s3"
        >scroll to see why ↓</a>
      </div>
    </section>

    {/* ─── Section 3: The main event ─── */}
    <section id="simulator" class="max-w-prose mx-auto py-20 border-t border-ink/10">
      <div class="flex items-start gap-4 mb-8">
        <img src="/chip-3.png" alt="" width="48" height="48" loading="lazy" class="section-chip-img hidden sm:block" />
        <h2 class="mt-0" style="margin-top: 0;">
          <img src="/chip-3.png" alt="" width="32" height="32" loading="lazy" class="section-chip-img inline sm:hidden mr-2 align-middle" />
          The main event
        </h2>
      </div>

      <p>Kelly gives you a number. The simulator lets you disobey it. Pick your bet, pick how much of Kelly to actually wager, and run it a thousand times to see what you'd have ended up with.</p>

      {/* Controls */}
      <div class="mt-10">
        <div class="sim-control-group">
          <label for="sim-bankroll">Starting bankroll (£)</label>
          <input type="range" id="sim-bankroll" min="0" max="3000" step="1" value="1000" />
          <div class="mt-1 text-center">
            <output for="sim-bankroll" class="font-mono text-sm" id="sim-bankroll-readout">£1,000</output>
          </div>
        </div>

        <div class="sim-control-group">
          <label for="sim-rounds">Number of rounds</label>
          <input type="range" id="sim-rounds" min="10" max="2000" step="10" value="500" />
          <div class="mt-1 text-center">
            <output for="sim-rounds" class="font-mono text-sm" id="sim-rounds-readout">500</output>
          </div>
        </div>

        <div class="sim-control-group">
          <label for="sim-p">Win probability (<em>p</em>)</label>
          <input type="range" id="sim-p" min="1" max="999" step="1" value="550" />
          <div class="mt-1 text-center">
            <output for="sim-p" class="font-mono text-sm" id="sim-p-readout">55.0%</output>
          </div>
        </div>

        <div class="sim-control-group">
          <label for="sim-b">Payout (<em>b</em>&thinsp;:&thinsp;1)</label>
          <input type="range" id="sim-b" min="0" max="3000" step="1" value="1000" />
          <div class="mt-1 text-center">
            <output for="sim-b" class="font-mono text-sm" id="sim-b-readout">1.0 : 1</output>
          </div>
        </div>

        <div class="sim-control-group">
          <label for="sim-kelly">Kelly multiplier</label>
          <div class="sim-control-note">1x = full Kelly. 0.5x = half Kelly. Anything above 2x enters territory where even a positive edge goes bankrupt.</div>
          <input type="range" id="sim-kelly" min="0" max="25" step="1" value="10" />
          <div class="mt-1 text-center">
            <output for="sim-kelly" class="font-mono text-sm" id="sim-kelly-readout">1.0x</output>
          </div>
        </div>

        <div class="sim-control-group">
          <label>Simulation paths</label>
          <div class="paths-btn-group">
            <button type="button" class="paths-btn" data-paths="100">100</button>
            <button type="button" class="paths-btn is-active" data-paths="1000">1K</button>
            <button type="button" class="paths-btn" data-paths="10000">10K</button>
          </div>
        </div>

      </div>

      {/* Preset rows */}
      <div class="mt-8">
        <div class="mb-4">
          <div class="text-sm font-medium mb-2">Scenarios</div>
          <div class="preset-row" role="group" aria-label="Scenario presets">
            <button type="button" class="preset-row-chip" data-scenario="biased-coin" aria-label="Biased Coin: p=0.55, b=1, £1,000, 500 rounds">🪙 Biased Coin</button>
            <button type="button" class="preset-row-chip" data-scenario="fair-coin" aria-label="Fair Coin: p=0.50, b=1, £1,000, 500 rounds">⚪ Fair Coin</button>
            <button type="button" class="preset-row-chip" data-scenario="card-counter" aria-label="Card Counter: p=0.51, b=1, £1,000, 2,000 rounds">🎯 Card Counter</button>
            <button type="button" class="preset-row-chip" data-scenario="eu-roulette" aria-label="EU Roulette: p=0.4865, b=1, £1,000, 500 rounds">🎰 EU Roulette</button>
            <button type="button" class="preset-row-chip" data-scenario="us-roulette" aria-label="US Roulette: p=0.4737, b=1, £1,000, 500 rounds">🎰 US Roulette</button>
            <button type="button" class="preset-row-chip" data-scenario="vc" aria-label="Pre-seed VC: p=0.1, b=20, £10,000, 30 rounds">🚀 Pre-seed VC</button>
          </div>
        </div>

        <div>
          <div class="text-sm font-medium mb-2">Kelly strategies</div>
          <div class="preset-row" role="group" aria-label="Kelly strategy presets">
            <button type="button" class="preset-row-chip" data-strategy="quarter" aria-label="Quarter Kelly: 0.25x">♠ Quarter Kelly</button>
            <button type="button" class="preset-row-chip" data-strategy="half" aria-label="Half Kelly: 0.5x">♥ Half Kelly</button>
            <button type="button" class="preset-row-chip" data-strategy="full" aria-label="Full Kelly: 1.0x">♦ Full Kelly</button>
            <button type="button" class="preset-row-chip" data-strategy="over" aria-label="Over-Kelly: 2.1x">♣ Over-Kelly</button>
          </div>
        </div>
      </div>

      {/* Figure 1: Kelly curve (analytical) */}
      <figure class="mt-10 mb-8">
        <div id="chart-kelly-curve" class="sim-chart-container" role="img" aria-label="Theoretical growth rate by Kelly multiplier"></div>
        <figcaption>Figure 1 - Theoretical growth rate by Kelly multiplier. Your current choice is marked. Above 2x, growth goes negative: even a positive-edge bet loses money on average.</figcaption>
      </figure>

      {/* Figure 2: Log-wealth trajectories */}
      <figure class="mb-8">
        <div id="chart-wealth" class="sim-chart-container" role="img" aria-label="Bankroll trajectory chart showing median and percentile bands">
          <div class="sim-chart-placeholder"><span class="text-card-red" style="font-size: 1.4rem; display: block; margin-bottom: 0.4rem;">♠</span><span style="font-variant: small-caps; font-style: italic;">Run the simulation to see the result</span></div>
        </div>
        <figcaption id="chart-wealth-caption">Figure 2 - Median bankroll trajectory, with 10th to 90th percentile band.</figcaption>
      </figure>

      {/* Run button + Reset */}
      <div class="mt-4 mb-2">
        <button type="button" id="sim-run" class="btn-primary w-full" style="font-size: 0.95rem; padding: 0.6rem 1rem;">Run simulation</button>
      </div>
      <div class="text-center mb-8">
        <a href="#" id="sim-reset" class="text-sm text-ink/40 hover:text-ink/60" style="text-decoration: none; font-style: italic;">Reset</a>
      </div>

      {/* Stats */}
      <div class="readout-grid" id="sim-stats" aria-live="polite" style="display: none;">
        <div class="readout-card">
          <div class="readout-label">Mean final wealth</div>
          <output class="readout-value block" id="stat-mean">-</output>
          <div class="readout-caption">mean can be misleading when the distribution is skewed; look at median too</div>
        </div>
        <div class="readout-card">
          <div class="readout-label">Bankruptcy rate</div>
          <output class="readout-value block" id="stat-bankrupt">-</output>
        </div>
        <div class="readout-card">
          <div class="readout-label">% of paths that beat starting bankroll</div>
          <output class="readout-value block" id="stat-beat">-</output>
        </div>
        <div class="readout-card readout-card-hero">
          <div class="readout-label">Median final wealth</div>
          <output class="readout-value block text-card-red font-bold" id="stat-median">-</output>
        </div>
      </div>

      {/* Transition prose */}
      <div class="mt-12">
        <p>Try the over-Kelly preset. Same coin, same edge. The only difference is bet size. Look at the bankruptcy rate.</p>

        <p>Most professional gamblers bet half Kelly, not full. The next section explains why.</p>

        <div class="text-center mt-6">
          <a href="#kelly" class="text-sm text-gold" style="text-decoration: none;" id="scroll-to-s4">scroll to see why ↓</a>
        </div>
      </div>
    </section>

    {/* ─── Stub sections 4–6 ─── */}
    {sections.map((s) => (
      <section id={s.id} class="max-w-prose mx-auto py-20 border-t border-ink/10">
        <div class="flex items-start gap-4 mb-8">
          <img src={`/chip-${s.num}.png`} alt="" width="48" height="48" loading="lazy" class="section-chip-img hidden sm:block" />
          <h2 class="mt-0" style="margin-top: 0;">
            <img src={`/chip-${s.num}.png`} alt="" width="32" height="32" loading="lazy" class="section-chip-img inline sm:hidden mr-2 align-middle" />
            {s.title}
          </h2>
        </div>
        <p class="text-ink/40 italic">Coming soon.</p>
      </section>
    ))}

    {/* ─── Footer ─── */}
    <footer class="max-w-prose mx-auto py-12 border-t border-ink/10 text-center text-sm text-ink/40">
      <p>♠ ♥ ♦ ♣</p>
    </footer>
  </main>

  <script>
    const slider = document.getElementById('bet-slider') as HTMLInputElement;
    const readout = document.getElementById('bet-readout')!;
    const lockBtn = document.getElementById('lock-bet') as HTMLButtonElement;
    const btnContainer = document.getElementById('bet-button-container')!;
    const responsePanel = document.getElementById('response-panel')!;
    const responseText = document.getElementById('response-text')!;

    // Update readout as slider moves
    slider.addEventListener('input', () => {
      const val = slider.value;
      readout.textContent = `£${val}`;
      slider.setAttribute('aria-valuenow', val);
      slider.setAttribute('aria-valuetext', `£${val}`);
    });

    // Tooltip tap-to-toggle on touch devices
    document.querySelectorAll('.tooltip-trigger').forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        trigger.classList.toggle('is-active');
      });

      trigger.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          trigger.classList.toggle('is-active');
        }
      });
    });

    // Close tooltips when clicking elsewhere
    document.addEventListener('click', (e) => {
      if (!(e.target as Element).closest('.tooltip-trigger')) {
        document.querySelectorAll('.tooltip-trigger.is-active').forEach((t) => {
          t.classList.remove('is-active');
        });
      }
    });

    // Lock in bet
    lockBtn.addEventListener('click', () => {
      const x = parseInt(slider.value, 10);

      // Disable slider
      slider.disabled = true;

      // Replace button with "Change my answer" link
      btnContainer.innerHTML =
        '<a href="#" id="change-answer" class="text-sm text-ink/40 hover:text-ink/60" style="text-decoration: none; font-style: italic;">Change my answer</a>';

      document.getElementById('change-answer')!.addEventListener('click', (e) => {
        e.preventDefault();
        slider.disabled = false;
        responsePanel.classList.remove('is-visible');
        btnContainer.innerHTML = '';
        btnContainer.appendChild(lockBtn);
      });

      // Build response
      const kellyLink =
        '<a href="https://en.wikipedia.org/wiki/Kelly_criterion" target="_blank" rel="noopener noreferrer" class="text-gold">Kelly Criterion</a>';

      let msg: string;

      if (x === 0) {
        msg = `Safe, but you're leaving money on the table. At a 55% win rate, the maths says you should be betting. You picked £0; the optimal bet is £100.`;
      } else if (x > 0 && x < 50) {
        msg = `Cautious. You picked £${x}. The mathematically optimal bet is £100, or 10% of your bankroll. You're on the right side of the line, but under-betting your edge.`;
      } else if (x >= 50 && x <= 150 && x !== 100) {
        msg = `Close. You picked £${x}. The mathematically optimal bet is £100, or 10% of your bankroll. You've clearly got the intuition; keep reading to see where the exact number comes from.`;
      } else if (x === 100) {
        msg = `Spot on. You picked £100, exactly 10% of your bankroll. You've just rediscovered the ${kellyLink}, the mathematically optimal bet for a 55/45 coin paying even money. Keep reading to see why.`;
      } else if (x > 150 && x <= 500) {
        msg = `Bold. You picked £${x}. The mathematically optimal bet is £100. Betting at this level, even with a positive edge, dramatically increases your chance of going broke before the edge compounds. Keep reading to see why.`;
      } else {
        msg = `Too bold. You picked £${x}. With this bet size, even a 55/45 edge mathematically guarantees ruin given enough rounds. The optimal bet is £100, or 10% of your bankroll. Keep reading to see why.`;
      }

      responseText.innerHTML = msg;

      // Show response
      requestAnimationFrame(() => {
        responsePanel.classList.add('is-visible');
      });
    });

    // Smooth scroll for the "scroll to see why" link
    document.getElementById('scroll-link')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('edge')?.scrollIntoView({ behavior: 'smooth' });
    });
  </script>

  <script>
    // ─── Section 2: Edge calculator ───

    const LOG_B_MIN = Math.log10(0.1);         // -1
    const LOG_B_MAX = Math.log10(2_000_000);    // ≈6.301
    const LOG_B_RANGE = LOG_B_MAX - LOG_B_MIN;  // ≈7.301

    function sliderToB(v: number): number {
      return Math.pow(10, (v / 1000) * LOG_B_RANGE + LOG_B_MIN);
    }

    function bToSlider(b: number): number {
      return ((Math.log10(b) - LOG_B_MIN) / LOG_B_RANGE) * 1000;
    }

    // Source-of-truth values (presets can set these outside slider range)
    let currentP = 0.55;
    let currentB = 1.0;

    const pSlider = document.getElementById('p-slider') as HTMLInputElement;
    const bSlider = document.getElementById('b-slider') as HTMLInputElement;
    const pReadout = document.getElementById('p-readout')!;
    const bReadout = document.getElementById('b-readout')!;
    const edgeOutput = document.getElementById('edge-output')!;
    const fairOutput = document.getElementById('fair-output')!;
    const kellyOutput = document.getElementById('kelly-output')!;
    const kellyCaption = document.getElementById('kelly-caption')!;
    const betS2Output = document.getElementById('bet-s2-output')!;

    const gbpFormat = new Intl.NumberFormat('en-GB', {
      style: 'currency',
      currency: 'GBP',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });

    const gbpWholeFormat = new Intl.NumberFormat('en-GB', {
      style: 'currency',
      currency: 'GBP',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    });

    const intlNumber = new Intl.NumberFormat('en-GB');

    function formatP(p: number): string {
      const pct = p * 100;
      if (pct >= 0.1) return pct.toFixed(1) + '%';
      if (p > 0) return '1 in ' + intlNumber.format(Math.round(1 / p));
      return '0.0%';
    }

    function formatB(b: number): string {
      if (b < 100) return b.toFixed(1) + ' : 1';
      return intlNumber.format(Math.round(b)) + ' : 1';
    }

    function formatFair(ratio: number): string {
      if (ratio < 100) return ratio.toFixed(2) + ' : 1';
      return intlNumber.format(Math.round(ratio)) + ' : 1';
    }

    function updateReadouts(): void {
      const p = currentP;
      const b = currentB;
      const q = 1 - p;
      const edge = b * p - q;
      const fair = q / p;
      const kelly = (b * p - q) / b;
      const suggestedBet = Math.max(0, kelly * 1000);

      // p readout
      pReadout.textContent = formatP(p);

      // b readout
      bReadout.textContent = formatB(b);

      // Edge
      const edgeSign = edge >= 0 ? '+' : '';
      edgeOutput.textContent = edgeSign + gbpFormat.format(edge);
      edgeOutput.style.color = edge < 0 ? '#a8252c' : '';

      // Fair payout
      fairOutput.textContent = formatFair(fair);

      // Kelly fraction
      if (kelly <= 0) {
        kellyOutput.textContent = '0.00%';
        kellyCaption.innerHTML = 'Kelly recommends not betting on negative-edge games';
      } else {
        kellyOutput.textContent = (kelly * 100).toFixed(2) + '%';
        kellyCaption.innerHTML = 'the Kelly fraction, <em>f</em> <sup style="font-size:0.65em">*</sup>';
      }

      // Suggested bet
      betS2Output.textContent = gbpWholeFormat.format(Math.round(suggestedBet));

      // Update slider ARIA
      pSlider.setAttribute('aria-valuenow', (p * 100).toFixed(1));
      pSlider.setAttribute('aria-valuetext', formatP(p));
      bSlider.setAttribute('aria-valuenow', b.toFixed(1));
      bSlider.setAttribute('aria-valuetext', formatB(b));
    }

    // Slider input handlers
    pSlider.addEventListener('input', () => {
      currentP = parseInt(pSlider.value, 10) / 1000;
      clearActiveChip();
      updateReadouts();
    });

    bSlider.addEventListener('input', () => {
      currentB = sliderToB(parseInt(bSlider.value, 10));
      clearActiveChip();
      updateReadouts();
    });

    // ─── Preset chips ───

    interface Preset {
      p: number;
      b: number;
    }

    const presets: Record<string, Preset> = {
      'lottery':       { p: 1 / 45_057_474, b: 1_899_999 },
      'us-roulette':   { p: 18 / 38,        b: 1 },
      'eu-roulette':   { p: 18 / 37,        b: 1 },
      'fair-coin':     { p: 0.5,            b: 1 },
      'biased-coin':   { p: 0.55,           b: 1 },
      'card-counter':  { p: 0.51,           b: 1 },
      'vc':            { p: 0.1,            b: 20 },
    };

    const chipButtons = document.querySelectorAll<HTMLButtonElement>('.preset-chip');
    let activeChip: HTMLButtonElement | null = null;

    function clearActiveChip(): void {
      if (activeChip) {
        activeChip.classList.remove('is-active');
        activeChip = null;
      }
    }

    function setActiveChip(btn: HTMLButtonElement): void {
      clearActiveChip();
      btn.classList.add('is-active');
      activeChip = btn;
    }

    // Check reduced-motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function animatePreset(targetP: number, targetB: number, btn: HTMLButtonElement): void {
      setActiveChip(btn);

      if (prefersReducedMotion) {
        // Instant update
        currentP = targetP;
        currentB = targetB;
        pSlider.value = String(Math.max(1, Math.min(999, Math.round(targetP * 1000))));
        bSlider.value = String(Math.max(0, Math.min(1000, Math.round(bToSlider(targetB)))));
        updateReadouts();
        return;
      }

      const startP = currentP;
      const startB = currentB;
      const startLogB = Math.log10(Math.max(startB, 1e-10));
      const targetLogB = Math.log10(Math.max(targetB, 1e-10));
      const duration = 300;
      const startTime = performance.now();

      function tick(now: number): void {
        const elapsed = now - startTime;
        const t = Math.min(elapsed / duration, 1);
        // Ease in-out quad
        const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

        currentP = startP + (targetP - startP) * ease;
        currentB = Math.pow(10, startLogB + (targetLogB - startLogB) * ease);

        // Position sliders (clamped to their ranges)
        pSlider.value = String(Math.max(1, Math.min(999, Math.round(currentP * 1000))));
        bSlider.value = String(Math.max(0, Math.min(1000, Math.round(bToSlider(currentB)))));

        updateReadouts();

        if (t < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    chipButtons.forEach((btn) => {
      const presetKey = btn.dataset.preset;
      if (!presetKey || !presets[presetKey]) return;

      btn.addEventListener('click', () => {
        const preset = presets[presetKey];
        animatePreset(preset.p, preset.b, btn);

        // Scroll calculator into view if off-screen
        const calc = document.getElementById('edge-calculator');
        if (calc) {
          const rect = calc.getBoundingClientRect();
          if (rect.top < 0 || rect.bottom > window.innerHeight) {
            calc.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'center' });
          }
        }
      });
    });

    // Chip tooltip: touch-to-toggle on mobile
    // On touch devices, first tap shows tooltip; second tap or tap-outside dismisses.
    // We detect touch via the 'ontouchstart' check.
    const isTouch = 'ontouchstart' in window;

    if (isTouch) {
      let activeTooltipChip: HTMLButtonElement | null = null;

      chipButtons.forEach((btn) => {
        btn.addEventListener('touchstart', (e) => {
          // If this chip already has tooltip showing, let the click through (applies preset)
          if (btn.classList.contains('tooltip-active')) {
            btn.classList.remove('tooltip-active');
            activeTooltipChip = null;
            return;
          }

          // Show tooltip on first tap, suppress click
          e.preventDefault();

          // Dismiss any other active tooltip
          if (activeTooltipChip && activeTooltipChip !== btn) {
            activeTooltipChip.classList.remove('tooltip-active');
          }

          btn.classList.add('tooltip-active');
          activeTooltipChip = btn;
        }, { passive: false });
      });

      // Dismiss tooltip on tap-outside
      document.addEventListener('touchstart', (e) => {
        if (activeTooltipChip && !(e.target as Element).closest('.preset-chip')) {
          activeTooltipChip.classList.remove('tooltip-active');
          activeTooltipChip = null;
        }
      });
    }

    // Scroll link for transition to section 3
    document.getElementById('scroll-to-s3')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('simulator')?.scrollIntoView({ behavior: 'smooth' });
    });

    // Initial render
    updateReadouts();
  </script>

  <script>
    // ─── Section 3: Simulator ───
    import * as Plot from "@observablehq/plot";
    import { runSimulation, kellyFraction, growthRate } from "../lib/kelly";
    import type { SimConfig, SimResult } from "../lib/kelly";

    // Log-scale helpers
    function sliderToBankroll(v: number): number {
      return Math.pow(10, (v / 3000) * 3 + 2);
    }
    function bankrollToSlider(val: number): number {
      return ((Math.log10(val) - 2) / 3) * 3000;
    }
    function sliderToSimB(v: number): number {
      return Math.pow(10, (v / 3000) * 3 - 1);
    }
    function simBToSlider(b: number): number {
      return ((Math.log10(b) + 1) / 3) * 3000;
    }

    // DOM refs
    const simBankrollSlider = document.getElementById('sim-bankroll') as HTMLInputElement;
    const simRoundsSlider = document.getElementById('sim-rounds') as HTMLInputElement;
    const simPSlider = document.getElementById('sim-p') as HTMLInputElement;
    const simBSlider = document.getElementById('sim-b') as HTMLInputElement;
    const simKellySlider = document.getElementById('sim-kelly') as HTMLInputElement;

    const simBankrollReadout = document.getElementById('sim-bankroll-readout')!;
    const simRoundsReadout = document.getElementById('sim-rounds-readout')!;
    const simPReadout = document.getElementById('sim-p-readout')!;
    const simBReadout = document.getElementById('sim-b-readout')!;
    const simKellyReadout = document.getElementById('sim-kelly-readout')!;

    const simRunBtn = document.getElementById('sim-run') as HTMLButtonElement;
    const simResetLink = document.getElementById('sim-reset')!;

    const chartWealthEl = document.getElementById('chart-wealth')!;
    const chartKellyEl = document.getElementById('chart-kelly-curve')!;
    const chartWealthCaption = document.getElementById('chart-wealth-caption')!;

    const statMedian = document.getElementById('stat-median')!;
    const statMean = document.getElementById('stat-mean')!;
    const statBankrupt = document.getElementById('stat-bankrupt')!;
    const statBeat = document.getElementById('stat-beat')!;
    const simStatsPanel = document.getElementById('sim-stats')!;

    // State
    let simPaths = 1000;
    // Previous stat values for tweening
    let prevStats = { median: 0, mean: 0, bankrupt: 0, beat: 0 };
    let hasRunOnce = false;

    const gbpSim = new Intl.NumberFormat('en-GB', {
      style: 'currency', currency: 'GBP',
      minimumFractionDigits: 0, maximumFractionDigits: 0,
    });
    const intlSim = new Intl.NumberFormat('en-GB');

    const simReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── Readout updaters ───

    function updateSimBankrollReadout(): void {
      simBankrollReadout.textContent = gbpSim.format(Math.round(sliderToBankroll(parseInt(simBankrollSlider.value))));
    }
    function updateSimRoundsReadout(): void {
      simRoundsReadout.textContent = simRoundsSlider.value;
    }
    function updateSimPReadout(): void {
      simPReadout.textContent = (parseInt(simPSlider.value) / 10).toFixed(1) + '%';
    }
    function updateSimBReadout(): void {
      const b = sliderToSimB(parseInt(simBSlider.value));
      simBReadout.textContent = (b < 100 ? b.toFixed(1) : Math.round(b).toString()) + ' : 1';
    }
    function updateSimKellyReadout(): void {
      simKellyReadout.textContent = (parseInt(simKellySlider.value) / 10).toFixed(1) + 'x';
    }
    function updateAllReadouts(): void {
      updateSimBankrollReadout();
      updateSimRoundsReadout();
      updateSimPReadout();
      updateSimBReadout();
      updateSimKellyReadout();
    }

    // ─── Preset row state ───

    function clearScenarioPreset(): void {
      document.querySelectorAll('[data-scenario].is-active').forEach(el => el.classList.remove('is-active'));
    }
    function clearStrategyPreset(): void {
      document.querySelectorAll('[data-strategy].is-active').forEach(el => el.classList.remove('is-active'));
    }

    // ─── Slider listeners ───

    simBankrollSlider.addEventListener('input', () => { updateSimBankrollReadout(); clearScenarioPreset(); });
    simRoundsSlider.addEventListener('input', () => { updateSimRoundsReadout(); clearScenarioPreset(); });
    simPSlider.addEventListener('input', () => { updateSimPReadout(); clearScenarioPreset(); renderKellyCurve(); });
    simBSlider.addEventListener('input', () => { updateSimBReadout(); clearScenarioPreset(); renderKellyCurve(); });
    simKellySlider.addEventListener('input', () => { updateSimKellyReadout(); clearStrategyPreset(); renderKellyCurve(); });

    // Paths buttons
    document.querySelectorAll<HTMLButtonElement>('.paths-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.paths-btn').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        simPaths = parseInt(btn.dataset.paths!);
      });
    });

    // ─── Build config from current sliders ───

    function getSimConfig(): SimConfig {
      return {
        bankroll: Math.round(sliderToBankroll(parseInt(simBankrollSlider.value))),
        rounds: parseInt(simRoundsSlider.value),
        p: parseInt(simPSlider.value) / 1000,
        b: sliderToSimB(parseInt(simBSlider.value)),
        kellyMultiplier: parseInt(simKellySlider.value) / 10,
        paths: simPaths,
      };
    }

    // ─── Chart: Log-wealth trajectories (Figure 2) ───

    function renderWealthChart(result: SimResult, config: SimConfig): void {
      const width = chartWealthEl.clientWidth || 600;
      const rounds = config.rounds;
      const startBankroll = config.bankroll;

      const data: { round: number; median: number; p10: number; p90: number }[] = [];
      for (let i = 0; i <= rounds; i++) {
        data.push({
          round: i,
          median: Math.max(result.medianTrajectory[i], 0.1),
          p10: Math.max(result.p10Trajectory[i], 0.1),
          p90: Math.max(result.p90Trajectory[i], 0.1),
        });
      }

      const maxP90 = Math.max(...result.p90Trajectory);
      const yTop = Math.max(maxP90 * 2, startBankroll * 10);
      const yBottom = Math.min(0.1, startBankroll * 0.01);

      const chart = Plot.plot({
        width,
        height: 320,
        style: {
          fontFamily: '"EB Garamond", Georgia, serif',
          fontSize: '13px',
          background: 'transparent',
        },
        x: { label: "Round", domain: [0, rounds] },
        y: {
          type: "log",
          label: "↑ Bankroll (£)",
          domain: [yBottom, yTop],
          grid: true,
          ticks: 6,
        },
        marks: [
          Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
          Plot.areaY(data, {
            x: "round", y1: "p10", y2: "p90",
            fill: "#a8252c", fillOpacity: 0.12,
            curve: "monotone-x",
          }),
          Plot.lineY(data, {
            x: "round", y: "median",
            stroke: "#a8252c", strokeWidth: 2.5,
            curve: "monotone-x",
          }),
          Plot.ruleY([startBankroll], {
            stroke: "#a8252c", strokeDasharray: "6,4", strokeOpacity: 0.4,
          }),
        ],
      });

      chartWealthEl.innerHTML = '';
      chartWealthEl.appendChild(chart);

      // Animate line draw-in and band fade-in
      if (!simReducedMotion) {
        const svg = chartWealthEl.querySelector('svg');
        if (svg) {
          // Find the median line (last path with card-red stroke)
          const paths = svg.querySelectorAll('path[stroke="#a8252c"]');
          const medianLine = paths[paths.length - 1];
          if (medianLine) {
            const len = (medianLine as SVGPathElement).getTotalLength();
            (medianLine as SVGElement).style.strokeDasharray = String(len);
            (medianLine as SVGElement).style.strokeDashoffset = String(len);
            (medianLine as SVGElement).style.transition = 'stroke-dashoffset 500ms ease-out';
            requestAnimationFrame(() => {
              (medianLine as SVGElement).style.strokeDashoffset = '0';
            });
          }
          // Find the area band (path with card-red fill)
          const band = svg.querySelector('path[fill="#a8252c"]');
          if (band) {
            (band as SVGElement).style.opacity = '0';
            (band as SVGElement).style.transition = 'opacity 500ms ease-out';
            requestAnimationFrame(() => {
              (band as SVGElement).style.opacity = '1';
            });
          }
        }
      }

      // All-bankrupt notice
      if (result.bankruptcyRate >= 1) {
        const bankruptRound = result.medianTrajectory.findIndex(v => v <= 0.01);
        const notice = document.createElement('div');
        notice.className = 'sim-chart-notice';
        notice.textContent = `All paths bankrupt by round ${bankruptRound > 0 ? bankruptRound : rounds}`;
        chartWealthEl.appendChild(notice);
      }

      chartWealthCaption.textContent =
        `Figure 2 - Median bankroll trajectory, with 10th to 90th percentile band, across ${intlSim.format(config.paths)} paths.`;
    }

    // ─── Chart: Kelly curve (Figure 1, analytical) ───

    function renderKellyCurve(): void {
      const width = chartKellyEl.clientWidth || 600;
      const p = parseInt(simPSlider.value) / 1000;
      const b = sliderToSimB(parseInt(simBSlider.value));
      const currentMult = parseInt(simKellySlider.value) / 10;
      const kelly = Math.abs(kellyFraction(p, b));

      const data: { mult: number; growth: number; pos: number; neg: number }[] = [];
      for (let m = 0; m <= 2.5; m += 0.005) {
        const f = kelly * m;
        let g: number;
        if (f <= 0) g = 0;
        else if (f >= 0.999) g = -0.5;
        else {
          g = growthRate(f, p, b);
          if (g < -0.5) g = -0.5;
        }
        data.push({
          mult: Math.round(m * 1000) / 1000,
          growth: g,
          pos: Math.max(0, g),
          neg: Math.min(0, g),
        });
      }

      const peakGrowth = kelly > 0 ? growthRate(kelly, p, b) : 0;
      const peakMarks = kelly > 0 ? [
        Plot.dot([{ x: 1, y: peakGrowth }], {
          x: "x", y: "y", fill: "#a8252c", r: 4,
        }),
        Plot.text([{ x: 1, y: peakGrowth }], {
          x: "x", y: "y", text: ["Full Kelly"],
          dy: -14, fill: "#a8252c", fontSize: 12, fontWeight: "600",
        }),
      ] : [];

      const chart = Plot.plot({
        width,
        height: 240,
        style: {
          fontFamily: '"EB Garamond", Georgia, serif',
          fontSize: '13px',
          background: 'transparent',
        },
        x: { label: "Kelly multiplier", domain: [0, 2.5] },
        y: { label: "↑ Growth rate (per round)", grid: true },
        marks: [
          Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
          Plot.areaY(data, { x: "mult", y: "pos", fill: "#a8252c", fillOpacity: 0.08, curve: "natural" }),
          Plot.areaY(data, { x: "mult", y: "neg", fill: "#6b7f5e", fillOpacity: 0.08, curve: "natural" }),
          Plot.ruleY([0], { stroke: "#1a1a1a", strokeOpacity: 0.15 }),
          Plot.lineY(data, { x: "mult", y: "growth", stroke: "#1a1a1a", strokeWidth: 2, curve: "natural" }),
          Plot.ruleX([currentMult], { stroke: "#a8252c", strokeWidth: 1.5, strokeDasharray: "4,3" }),
          ...peakMarks,
        ],
      });

      chartKellyEl.innerHTML = '';
      chartKellyEl.appendChild(chart);
    }

    // ─── Stats with animated tweening ───

    function tweenStats(result: SimResult): void {
      const targets = {
        median: Math.round(result.medianFinal),
        mean: Math.round(result.meanFinal),
        bankrupt: result.bankruptcyRate * 100,
        beat: result.beatStartRate * 100,
      };

      if (simReducedMotion || !hasRunOnce) {
        statMedian.textContent = gbpSim.format(targets.median);
        statMean.textContent = gbpSim.format(targets.mean);
        statBankrupt.textContent = targets.bankrupt.toFixed(1) + '%';
        statBeat.textContent = targets.beat.toFixed(1) + '%';
        prevStats = targets;
        hasRunOnce = true;
        return;
      }

      const starts = { ...prevStats };
      const duration = 700;
      const startTime = performance.now();

      function tick(now: number): void {
        const elapsed = now - startTime;
        const t = Math.min(elapsed / duration, 1);
        // Ease-out cubic
        const ease = 1 - Math.pow(1 - t, 3);

        const curMedian = starts.median + (targets.median - starts.median) * ease;
        const curMean = starts.mean + (targets.mean - starts.mean) * ease;
        const curBankrupt = starts.bankrupt + (targets.bankrupt - starts.bankrupt) * ease;
        const curBeat = starts.beat + (targets.beat - starts.beat) * ease;

        statMedian.textContent = gbpSim.format(Math.round(curMedian));
        statMean.textContent = gbpSim.format(Math.round(curMean));
        statBankrupt.textContent = curBankrupt.toFixed(1) + '%';
        statBeat.textContent = curBeat.toFixed(1) + '%';

        if (t < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
      prevStats = targets;
      hasRunOnce = true;
    }

    // ─── Run simulation ───

    let runLocked = false;

    async function doRun(): Promise<void> {
      if (runLocked) return;
      runLocked = true;
      simRunBtn.textContent = 'Running…';
      simRunBtn.disabled = true;
      const runStartTime = performance.now();

      // Yield to browser for paint
      await new Promise<void>(r => requestAnimationFrame(() => requestAnimationFrame(() => r())));

      const config = getSimConfig();
      const result = runSimulation(config);

      renderWealthChart(result, config);
      renderKellyCurve();

      // Reveal stats panel on first run
      if (simStatsPanel.style.display === 'none') {
        simStatsPanel.style.display = '';
        if (!simReducedMotion) {
          simStatsPanel.style.opacity = '0';
          simStatsPanel.style.transition = 'opacity 200ms ease';
          requestAnimationFrame(() => { simStatsPanel.style.opacity = '1'; });
        }
      }

      tweenStats(result);

      // Enforce minimum 300ms "Running…" display
      const elapsed = performance.now() - runStartTime;
      const remaining = Math.max(0, 300 - elapsed);

      // Re-enable after 700ms total for stat tween to finish
      const reEnableDelay = simReducedMotion ? remaining : Math.max(remaining, 700);

      setTimeout(() => {
        simRunBtn.textContent = 'Run simulation';
        simRunBtn.disabled = false;
        runLocked = false;
      }, reEnableDelay);
    }

    simRunBtn.addEventListener('click', doRun);

    // ─── Reset ───

    simResetLink.addEventListener('click', (e) => {
      e.preventDefault();
      simBankrollSlider.value = '1000';
      simRoundsSlider.value = '500';
      simPSlider.value = '550';
      simBSlider.value = '1000';
      simKellySlider.value = '10';
      simPaths = 1000;

      document.querySelectorAll('.paths-btn').forEach(b => {
        b.classList.toggle('is-active', (b as HTMLElement).dataset.paths === '1000');
      });

      updateAllReadouts();
      clearScenarioPreset();
      clearStrategyPreset();

      chartWealthEl.innerHTML = '<div class="sim-chart-placeholder"><span class="text-card-red" style="font-size: 1.4rem; display: block; margin-bottom: 0.4rem;">♠</span><span style="font-variant: small-caps; font-style: italic;">Run the simulation to see the result</span></div>';
      simStatsPanel.style.display = 'none';
      simStatsPanel.style.opacity = '';
      simStatsPanel.style.transition = '';
      statMedian.textContent = '-';
      statMean.textContent = '-';
      statBankrupt.textContent = '-';
      statBeat.textContent = '-';
      prevStats = { median: 0, mean: 0, bankrupt: 0, beat: 0 };
      hasRunOnce = false;

      renderKellyCurve();
    });

    // ─── Scenario presets (Row A) ───

    interface Scenario { bankroll: number; rounds: number; p: number; b: number; }

    const scenarios: Record<string, Scenario> = {
      'biased-coin':  { bankroll: 1000,  rounds: 500,  p: 0.55,   b: 1 },
      'fair-coin':    { bankroll: 1000,  rounds: 500,  p: 0.50,   b: 1 },
      'card-counter': { bankroll: 1000,  rounds: 2000, p: 0.51,   b: 1 },
      'eu-roulette':  { bankroll: 1000,  rounds: 500,  p: 0.4865, b: 1 },
      'us-roulette':  { bankroll: 1000,  rounds: 500,  p: 0.4737, b: 1 },
      'vc':           { bankroll: 10000, rounds: 30,   p: 0.1,    b: 20 },
    };

    document.querySelectorAll<HTMLButtonElement>('[data-scenario]').forEach(btn => {
      const key = btn.dataset.scenario!;
      if (!scenarios[key]) return;

      btn.addEventListener('click', () => {
        const s = scenarios[key];
        simBankrollSlider.value = String(Math.round(bankrollToSlider(s.bankroll)));
        simRoundsSlider.value = String(s.rounds);
        simPSlider.value = String(Math.round(s.p * 1000));
        simBSlider.value = String(Math.round(simBToSlider(s.b)));
        updateAllReadouts();

        clearScenarioPreset();
        btn.classList.add('is-active');

        doRun();
      });
    });

    // ─── Strategy presets (Row B) ───

    const strategies: Record<string, number> = {
      'quarter': 0.25,
      'half':    0.5,
      'full':    1.0,
      'over':    2.1,
    };

    document.querySelectorAll<HTMLButtonElement>('[data-strategy]').forEach(btn => {
      const key = btn.dataset.strategy!;
      if (!(key in strategies)) return;

      btn.addEventListener('click', () => {
        simKellySlider.value = String(Math.round(strategies[key] * 10));
        updateSimKellyReadout();

        clearStrategyPreset();
        btn.classList.add('is-active');

        renderKellyCurve();
        doRun();
      });
    });

    // Scroll link
    document.getElementById('scroll-to-s4')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('kelly')?.scrollIntoView({ behavior: 'smooth' });
    });

    // Initial Kelly curve render
    renderKellyCurve();
  </script>
</Base>
