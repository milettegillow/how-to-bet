  <script>
    import { track as s1Track } from '../lib/analytics';

    const slider = document.getElementById('bet-slider') as HTMLInputElement;
    const readout = document.getElementById('bet-readout')!;
    const lockBtn = document.getElementById('lock-bet') as HTMLButtonElement;
    const btnContainer = document.getElementById('bet-button-container')!;
    const responsePanel = document.getElementById('response-panel')!;
    const responseText = document.getElementById('response-text')!;

    // Update readout as slider moves
    slider.addEventListener('input', () => {
      const val = slider.value;
      readout.textContent = `£${val}`;
      slider.setAttribute('aria-valuenow', val);
      slider.setAttribute('aria-valuetext', `£${val}`);
    });

    // ─── Portal tooltip system ───
    const tooltipEl = document.createElement('div');
    tooltipEl.className = 'tooltip-portal';
    tooltipEl.setAttribute('role', 'tooltip');
    const tooltipArrow = document.createElement('div');
    tooltipArrow.className = 'tooltip-portal-arrow';
    tooltipEl.appendChild(tooltipArrow);
    const tooltipBody = document.createElement('span');
    tooltipEl.appendChild(tooltipBody);
    document.body.appendChild(tooltipEl);

    let activeTrigger: Element | null = null;

    function positionTooltip(trigger: Element): void {
      const rect = trigger.getBoundingClientRect();
      const gap = 8;

      tooltipEl.style.visibility = 'hidden';
      tooltipEl.style.display = 'block';
      tooltipEl.classList.add('is-visible');
      const ttRect = tooltipEl.getBoundingClientRect();

      // Default: above
      let top = rect.top - ttRect.height - gap;
      let placeBelow = false;

      if (top < 4) {
        // Not enough room above, flip below
        top = rect.bottom + gap;
        placeBelow = true;
      }

      // Centre horizontally on the trigger
      let left = rect.left + rect.width / 2 - ttRect.width / 2;

      // Clamp to viewport edges
      const margin = 8;
      if (left < margin) left = margin;
      if (left + ttRect.width > window.innerWidth - margin) {
        left = window.innerWidth - margin - ttRect.width;
      }

      tooltipEl.style.top = top + 'px';
      tooltipEl.style.left = left + 'px';
      tooltipEl.style.visibility = '';

      // Position arrow
      tooltipArrow.className = 'tooltip-portal-arrow ' + (placeBelow ? 'arrow-up' : 'arrow-down');
      const arrowLeft = rect.left + rect.width / 2 - left;
      tooltipArrow.style.left = arrowLeft + 'px';
      tooltipArrow.style.transform = 'translateX(-50%)';
    }

    function showTooltip(trigger: Element): void {
      const text = trigger.getAttribute('data-tooltip');
      if (!text) return;

      // Dismiss any open tooltip
      hideTooltip();

      const id = trigger.getAttribute('data-tooltip-id') || '';
      tooltipEl.id = id;
      tooltipBody.textContent = text;
      activeTrigger = trigger;

      positionTooltip(trigger);
    }

    function hideTooltip(): void {
      tooltipEl.classList.remove('is-visible');
      tooltipEl.style.display = 'none';
      activeTrigger = null;
    }

    // Hover: show on mouseenter, hide on mouseleave
    document.addEventListener('mouseenter', (e) => {
      const trigger = (e.target as Element).closest?.('.tooltip-trigger');
      if (trigger) showTooltip(trigger);
    }, true);

    document.addEventListener('mouseleave', (e) => {
      const trigger = (e.target as Element).closest?.('.tooltip-trigger');
      if (trigger && trigger === activeTrigger) hideTooltip();
    }, true);

    // Click / tap: toggle
    document.querySelectorAll('.tooltip-trigger').forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (activeTrigger === trigger) {
          hideTooltip();
        } else {
          showTooltip(trigger);
        }
      });

      trigger.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        if (key === 'Enter' || key === ' ') {
          e.preventDefault();
          e.stopPropagation();
          if (activeTrigger === trigger) {
            hideTooltip();
          } else {
            showTooltip(trigger);
          }
        }
      });
    });

    // Dismiss on click outside
    document.addEventListener('click', (e) => {
      if (activeTrigger && !(e.target as Element).closest('.tooltip-trigger')) {
        hideTooltip();
      }
    });

    // Dismiss on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && activeTrigger) hideTooltip();
    });

    // Reposition on scroll/resize
    let repositionFrame = 0;
    function handleReposition(): void {
      if (repositionFrame) return;
      repositionFrame = requestAnimationFrame(() => {
        repositionFrame = 0;
        if (activeTrigger) positionTooltip(activeTrigger);
      });
    }
    window.addEventListener('scroll', handleReposition, { passive: true });
    window.addEventListener('resize', handleReposition, { passive: true });

    // Lock in bet
    lockBtn.addEventListener('click', () => {
      const x = parseInt(slider.value, 10);

      // Disable slider
      slider.disabled = true;

      // Replace button with "Change my answer" link
      btnContainer.innerHTML =
        '<a href="#" id="change-answer" class="text-sm text-ink/40 hover:text-ink/60" style="text-decoration: none; font-style: italic;">Change my answer</a>';

      document.getElementById('change-answer')!.addEventListener('click', (e) => {
        e.preventDefault();
        slider.disabled = false;
        responsePanel.classList.remove('is-visible');
        btnContainer.innerHTML = '';
        btnContainer.appendChild(lockBtn);
      });

      // Build response
      const kellyLink =
        '<a href="https://en.wikipedia.org/wiki/Kelly_criterion" target="_blank" rel="noopener noreferrer" class="text-gold">Kelly Criterion</a>';

      let msg: string;

      if (x === 0) {
        msg = `Safe, but you're leaving money on the table. At a 55% win rate, the maths says you should be betting. You picked £0; the optimal bet is £100.`;
      } else if (x > 0 && x < 50) {
        msg = `Cautious. You picked £${x}. The mathematically optimal bet is £100, or 10% of your bankroll. You're on the right side of the line, but under-betting your edge.`;
      } else if (x >= 50 && x <= 150 && x !== 100) {
        msg = `Close. You picked £${x}. The mathematically optimal bet is £100, or 10% of your bankroll. You've clearly got the intuition; keep reading to see where the exact number comes from.`;
      } else if (x === 100) {
        msg = `Spot on. You picked £100, exactly 10% of your bankroll. You've just rediscovered the ${kellyLink}, the mathematically optimal bet for a 55/45 coin paying even money. Keep reading to see why.`;
      } else if (x > 150 && x <= 500) {
        msg = `Bold. You picked £${x}. The mathematically optimal bet is £100. Betting at this level, even with a positive edge, dramatically increases your chance of going broke before the edge compounds. Keep reading to see why.`;
      } else {
        msg = `Too bold. You picked £${x}. With this bet size, even a 55/45 edge mathematically guarantees ruin given enough rounds. The optimal bet is £100, or 10% of your bankroll. Keep reading to see why.`;
      }

      responseText.innerHTML = msg;
      s1Track('s1_bet_locked');

      // Show response
      requestAnimationFrame(() => {
        responsePanel.classList.add('is-visible');
      });
    });

    // Smooth scroll for the "scroll to see why" link
    document.getElementById('scroll-link')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('edge')?.scrollIntoView({ behavior: 'smooth' });
    });
  </script>

  <script>
    // ─── Section 2: Edge calculator ───
    import { track as s2Track } from '../lib/analytics';

    const LOG_B_MIN = Math.log10(0.1);         // -1
    const LOG_B_MAX = Math.log10(2_000_000);    // ≈6.301
    const LOG_B_RANGE = LOG_B_MAX - LOG_B_MIN;  // ≈7.301

    function sliderToB(v: number): number {
      return Math.pow(10, (v / 1000) * LOG_B_RANGE + LOG_B_MIN);
    }

    function bToSlider(b: number): number {
      return ((Math.log10(b) - LOG_B_MIN) / LOG_B_RANGE) * 1000;
    }

    // Source-of-truth values (presets can set these outside slider range)
    let currentP = 0.55;
    let currentB = 1.0;

    const pSlider = document.getElementById('p-slider') as HTMLInputElement;
    const bSlider = document.getElementById('b-slider') as HTMLInputElement;
    const pReadout = document.getElementById('p-readout')!;
    const bReadout = document.getElementById('b-readout')!;
    const edgeOutput = document.getElementById('edge-output')!;
    const fairOutput = document.getElementById('fair-output')!;
    const kellyOutput = document.getElementById('kelly-output')!;
    const kellyCaption = document.getElementById('kelly-caption')!;
    const betS2Output = document.getElementById('bet-s2-output')!;

    const gbpFormat = new Intl.NumberFormat('en-GB', {
      style: 'currency',
      currency: 'GBP',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });

    const gbpWholeFormat = new Intl.NumberFormat('en-GB', {
      style: 'currency',
      currency: 'GBP',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    });

    const intlNumber = new Intl.NumberFormat('en-GB');

    function formatP(p: number): string {
      const pct = p * 100;
      if (pct >= 0.1) return pct.toFixed(1) + '%';
      if (p > 0) return '1 in ' + intlNumber.format(Math.round(1 / p));
      return '0.0%';
    }

    function formatB(b: number): string {
      if (b < 100) return b.toFixed(1) + ' : 1';
      return intlNumber.format(Math.round(b)) + ' : 1';
    }

    function formatFair(ratio: number): string {
      if (ratio < 100) return ratio.toFixed(2) + ' : 1';
      return intlNumber.format(Math.round(ratio)) + ' : 1';
    }

    function updateReadouts(): void {
      const p = currentP;
      const b = currentB;
      const q = 1 - p;
      const edge = b * p - q;
      const fair = q / p;
      const kelly = (b * p - q) / b;
      const suggestedBet = Math.max(0, kelly * 1000);

      // p readout
      pReadout.textContent = formatP(p);

      // b readout
      bReadout.textContent = formatB(b);

      // Edge
      const edgeSign = edge >= 0 ? '+' : '';
      edgeOutput.textContent = edgeSign + gbpFormat.format(edge);
      edgeOutput.style.color = edge < 0 ? '#a8252c' : '';

      // Fair payout
      fairOutput.textContent = formatFair(fair);

      // Kelly fraction
      if (kelly <= 0) {
        kellyOutput.textContent = '0.00%';
        kellyCaption.innerHTML = 'Kelly recommends not betting on negative-edge games';
      } else {
        kellyOutput.textContent = (kelly * 100).toFixed(2) + '%';
        kellyCaption.innerHTML = 'the Kelly fraction, <em>f</em> <sup style="font-size:0.65em">*</sup>';
      }

      // Suggested bet
      betS2Output.textContent = gbpWholeFormat.format(Math.round(suggestedBet));

      // Update slider ARIA
      pSlider.setAttribute('aria-valuenow', (p * 100).toFixed(1));
      pSlider.setAttribute('aria-valuetext', formatP(p));
      bSlider.setAttribute('aria-valuenow', b.toFixed(1));
      bSlider.setAttribute('aria-valuetext', formatB(b));
    }

    // Slider input handlers
    pSlider.addEventListener('input', () => {
      currentP = parseInt(pSlider.value, 10) / 1000;
      clearActiveChip();
      updateReadouts();
    });

    bSlider.addEventListener('input', () => {
      currentB = sliderToB(parseInt(bSlider.value, 10));
      clearActiveChip();
      updateReadouts();
    });

    // ─── Preset chips ───

    interface Preset {
      p: number;
      b: number;
    }

    const presets: Record<string, Preset> = {
      'lottery':       { p: 1 / 45_057_474, b: 1_899_999 },
      'us-roulette':   { p: 18 / 38,        b: 1 },
      'eu-roulette':   { p: 18 / 37,        b: 1 },
      'fair-coin':     { p: 0.5,            b: 1 },
      'biased-coin':   { p: 0.55,           b: 1 },
      'card-counter':  { p: 0.51,           b: 1 },
      'vc':            { p: 0.1,            b: 20 },
    };

    const chipButtons = document.querySelectorAll<HTMLButtonElement>('.preset-chip');
    let activeChip: HTMLButtonElement | null = null;

    function clearActiveChip(): void {
      if (activeChip) {
        activeChip.classList.remove('is-active');
        activeChip = null;
      }
    }

    function setActiveChip(btn: HTMLButtonElement): void {
      clearActiveChip();
      btn.classList.add('is-active');
      activeChip = btn;
    }

    // Check reduced-motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function animatePreset(targetP: number, targetB: number, btn: HTMLButtonElement): void {
      setActiveChip(btn);

      if (prefersReducedMotion) {
        // Instant update
        currentP = targetP;
        currentB = targetB;
        pSlider.value = String(Math.max(1, Math.min(999, Math.round(targetP * 1000))));
        bSlider.value = String(Math.max(0, Math.min(1000, Math.round(bToSlider(targetB)))));
        updateReadouts();
        return;
      }

      const startP = currentP;
      const startB = currentB;
      const startLogB = Math.log10(Math.max(startB, 1e-10));
      const targetLogB = Math.log10(Math.max(targetB, 1e-10));
      const duration = 300;
      const startTime = performance.now();

      function tick(now: number): void {
        const elapsed = now - startTime;
        const t = Math.min(elapsed / duration, 1);
        // Ease in-out quad
        const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

        currentP = startP + (targetP - startP) * ease;
        currentB = Math.pow(10, startLogB + (targetLogB - startLogB) * ease);

        // Position sliders (clamped to their ranges)
        pSlider.value = String(Math.max(1, Math.min(999, Math.round(currentP * 1000))));
        bSlider.value = String(Math.max(0, Math.min(1000, Math.round(bToSlider(currentB)))));

        updateReadouts();

        if (t < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    chipButtons.forEach((btn) => {
      const presetKey = btn.dataset.preset;
      if (!presetKey || !presets[presetKey]) return;

      btn.addEventListener('click', () => {
        const preset = presets[presetKey];
        animatePreset(preset.p, preset.b, btn);
        s2Track('s2_preset_clicked');

        // Scroll calculator into view if off-screen
        const calc = document.getElementById('edge-calculator');
        if (calc) {
          const rect = calc.getBoundingClientRect();
          if (rect.top < 0 || rect.bottom > window.innerHeight) {
            calc.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'center' });
          }
        }
      });
    });

    // Chip tooltip: touch-to-toggle on mobile
    // On touch devices, first tap shows tooltip; second tap or tap-outside dismisses.
    // We detect touch via the 'ontouchstart' check.
    const isTouch = 'ontouchstart' in window;

    if (isTouch) {
      let activeTooltipChip: HTMLButtonElement | null = null;

      chipButtons.forEach((btn) => {
        btn.addEventListener('touchstart', (e) => {
          // If this chip already has tooltip showing, let the click through (applies preset)
          if (btn.classList.contains('tooltip-active')) {
            btn.classList.remove('tooltip-active');
            activeTooltipChip = null;
            return;
          }

          // Show tooltip on first tap, suppress click
          e.preventDefault();

          // Dismiss any other active tooltip
          if (activeTooltipChip && activeTooltipChip !== btn) {
            activeTooltipChip.classList.remove('tooltip-active');
          }

          btn.classList.add('tooltip-active');
          activeTooltipChip = btn;
        }, { passive: false });
      });

      // Dismiss tooltip on tap-outside
      document.addEventListener('touchstart', (e) => {
        if (activeTooltipChip && !(e.target as Element).closest('.preset-chip')) {
          activeTooltipChip.classList.remove('tooltip-active');
          activeTooltipChip = null;
        }
      });
    }

    // Scroll link for transition to section 3
    document.getElementById('scroll-to-s3')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('simulator')?.scrollIntoView({ behavior: 'smooth' });
    });

    // Initial render
    updateReadouts();
  </script>

  <script>
    // ─── Section 3: Simulator ───
    import * as Plot from "@observablehq/plot";
    import { runSimulation, kellyFraction, growthRate } from "../lib/kelly";
    import type { SimConfig, SimResult } from "../lib/kelly";
    import { formatCurrency } from "../lib/format";
    import { track } from '../lib/analytics';

    // Log-scale helper for payout slider
    function sliderToSimB(v: number): number {
      return Math.pow(10, (v / 3000) * 3 - 1);
    }
    function simBToSlider(b: number): number {
      return ((Math.log10(b) + 1) / 3) * 3000;
    }

    // DOM refs
    const simRoundsSlider = document.getElementById('sim-rounds') as HTMLInputElement;
    const simPSlider = document.getElementById('sim-p') as HTMLInputElement;
    const simBSlider = document.getElementById('sim-b') as HTMLInputElement;

    const simRoundsReadout = document.getElementById('sim-rounds-readout')!;
    const simPReadout = document.getElementById('sim-p-readout')!;
    const simBReadout = document.getElementById('sim-b-readout')!;

    const simRunBtn = document.getElementById('sim-run') as HTMLButtonElement;
    const simResetLink = document.getElementById('sim-reset')!;

    const chartWealthEl = document.getElementById('chart-wealth')!;
    const chartKellyEl = document.getElementById('chart-kelly-curve')!;
    const chartWealthCaption = document.getElementById('chart-wealth-caption')!;

    const kellySaysEl = document.getElementById('kelly-says')!;
    const summaryOdds = document.getElementById('summary-odds')!;
    const summaryPayout = document.getElementById('summary-payout')!;
    const summaryBet = document.getElementById('summary-bet')!;

    const statMedian = document.getElementById('stat-median')!;
    const statMean = document.getElementById('stat-mean')!;
    const statBankrupt = document.getElementById('stat-bankrupt')!;
    const statBeat = document.getElementById('stat-beat')!;
    // State
    let simBankroll = 1000;
    let simKellyMult = 1.0;
    let prevStats = { median: 0, mean: 0, bankrupt: 0, beat: 0 };
    let hasRunOnce = false;

    const intlSim = new Intl.NumberFormat('en-GB');
    const simReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── Readout updaters ───

    function updateSimRoundsReadout(): void {
      simRoundsReadout.textContent = simRoundsSlider.value;
    }
    function updateSimPReadout(): void {
      simPReadout.textContent = (parseInt(simPSlider.value) / 10).toFixed(1) + '%';
    }
    function updateSimBReadout(): void {
      const b = sliderToSimB(parseInt(simBSlider.value));
      simBReadout.textContent = (b < 100 ? b.toFixed(1) : Math.round(b).toString()) + ' : 1';
    }
    function updateAllReadouts(): void {
      updateSimRoundsReadout();
      updateSimPReadout();
      updateSimBReadout();
    }

    // ─── Kelly info display ───

    function getCurrentKelly(): number {
      const p = parseInt(simPSlider.value) / 1000;
      const b = sliderToSimB(parseInt(simBSlider.value));
      return kellyFraction(p, b);
    }

    function updateKellyDisplay(): void {
      const kf = getCurrentKelly();
      const p = parseInt(simPSlider.value) / 1000;
      const b = sliderToSimB(parseInt(simBSlider.value));

      if (kf <= 0) {
        kellySaysEl.textContent = "Kelly suggests not betting on this scenario.";
        summaryOdds.textContent = (p * 100).toFixed(1) + '%';
        summaryPayout.textContent = '-';
        summaryPayout.style.color = '';
        summaryBet.innerHTML = '£0';
        document.querySelectorAll<HTMLButtonElement>('[data-kelly-mult]').forEach(btn => {
          btn.style.opacity = '0.4';
          btn.style.cursor = 'not-allowed';
          btn.dataset.disabled = '1';
        });
        // Remove gold tint from rec button when disabled
        const recBtn = document.querySelector<HTMLButtonElement>('.kelly-btn-rec');
        if (recBtn) recBtn.style.background = '';
        document.getElementById('bet-summary')!.style.opacity = '0.5';
      } else {
        const kellyBet = kf * simBankroll;
        const kellyPct = (kf * 100).toFixed(1);
        kellySaysEl.innerHTML = `Kelly suggests betting ${kellyPct}% of bankroll, i.e. ${formatCurrency(Math.round(kellyBet))}.`;
        document.querySelectorAll<HTMLButtonElement>('[data-kelly-mult]').forEach(btn => {
          btn.style.opacity = '';
          btn.style.cursor = '';
          delete btn.dataset.disabled;
        });
        // Restore gold tint on rec button
        const recBtn = document.querySelector<HTMLButtonElement>('.kelly-btn-rec');
        if (recBtn) recBtn.style.background = '';
        document.getElementById('bet-summary')!.style.opacity = '';

        const actualFrac = Math.abs(kf) * simKellyMult;
        const actualBet = actualFrac * simBankroll;
        const winProfit = actualBet * b;

        summaryOdds.textContent = (p * 100).toFixed(1) + '%';
        summaryPayout.innerHTML = formatCurrency(Math.round(winProfit));
        summaryPayout.style.color = '';
        summaryBet.innerHTML = formatCurrency(Math.round(actualBet));
      }
    }

    // ─── Preset row state ───

    function clearScenarioPreset(): void {
      document.querySelectorAll('[data-scenario].is-active').forEach(el => el.classList.remove('is-active'));
    }
    // ─── Slider listeners ───

    simRoundsSlider.addEventListener('input', () => { updateSimRoundsReadout(); clearScenarioPreset(); });
    simPSlider.addEventListener('input', () => { updateSimPReadout(); clearScenarioPreset(); renderKellyCurve(); updateKellyDisplay(); });
    simBSlider.addEventListener('input', () => { updateSimBReadout(); clearScenarioPreset(); renderKellyCurve(); updateKellyDisplay(); });

    // Bankroll buttons
    document.querySelectorAll<HTMLButtonElement>('[data-bankroll]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-bankroll]').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        simBankroll = parseInt(btn.dataset.bankroll!);
        clearScenarioPreset();
        updateKellyDisplay();
      });
    });

    // Kelly multiplier buttons
    document.querySelectorAll<HTMLButtonElement>('[data-kelly-mult]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (btn.dataset.disabled === '1') return;
        document.querySelectorAll('[data-kelly-mult]').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        simKellyMult = parseFloat(btn.dataset.kellyMult!);
        updateKellyDisplay();
        renderKellyCurve();
        doRun();
      });
    });

    // ─── Build config from current controls ───

    function getSimConfig(): SimConfig {
      return {
        bankroll: simBankroll,
        rounds: parseInt(simRoundsSlider.value),
        p: parseInt(simPSlider.value) / 1000,
        b: sliderToSimB(parseInt(simBSlider.value)),
        kellyMultiplier: simKellyMult,
        paths: 1000,
      };
    }

    // ─── Chart: Log-wealth trajectories (Figure 2) ───

    function renderWealthChart(result: SimResult, config: SimConfig): void {
      const width = chartWealthEl.clientWidth || 600;
      const rounds = config.rounds;
      const startBankroll = config.bankroll;

      const data: { round: number; median: number; p10: number; p90: number }[] = [];
      for (let i = 0; i <= rounds; i++) {
        data.push({
          round: i,
          median: Math.max(result.medianTrajectory[i], 0.1),
          p10: Math.max(result.p10Trajectory[i], 0.1),
          p90: Math.max(result.p90Trajectory[i], 0.1),
        });
      }

      const maxP90 = Math.max(...result.p90Trajectory);
      const yTop = Math.max(maxP90 * 2, startBankroll * 10);
      const yBottom = Math.min(0.1, startBankroll * 0.01);

      const chart = Plot.plot({
        width,
        height: 320,
        style: {
          fontFamily: '"EB Garamond", Georgia, serif',
          fontSize: '13px',
          background: 'transparent',
        },
        x: { label: "Bet number", domain: [0, rounds] },
        y: {
          type: "log",
          label: "↑ Bankroll (£)",
          domain: [yBottom, yTop],
          grid: true,
          ticks: 6,
        },
        marks: [
          Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
          Plot.areaY(data, {
            x: "round", y1: "p10", y2: "p90",
            fill: "#a8252c", fillOpacity: 0.12,
            curve: "monotone-x",
          }),
          Plot.lineY(data, {
            x: "round", y: "median",
            stroke: "#a8252c", strokeWidth: 2.5,
            curve: "monotone-x",
          }),
          Plot.ruleY([startBankroll], {
            stroke: "#a8252c", strokeDasharray: "6,4", strokeOpacity: 0.4,
          }),
        ],
      });

      chartWealthEl.innerHTML = '';
      chartWealthEl.appendChild(chart);

      // Animate line draw-in and band fade-in
      if (!simReducedMotion) {
        const svg = chartWealthEl.querySelector('svg');
        if (svg) {
          const paths = svg.querySelectorAll('path[stroke="#a8252c"]');
          const medianLine = paths[paths.length - 1];
          if (medianLine) {
            const len = (medianLine as SVGPathElement).getTotalLength();
            (medianLine as SVGElement).style.strokeDasharray = String(len);
            (medianLine as SVGElement).style.strokeDashoffset = String(len);
            (medianLine as SVGElement).style.transition = 'stroke-dashoffset 500ms ease-out';
            requestAnimationFrame(() => {
              (medianLine as SVGElement).style.strokeDashoffset = '0';
            });
          }
          const band = svg.querySelector('path[fill="#a8252c"]');
          if (band) {
            (band as SVGElement).style.opacity = '0';
            (band as SVGElement).style.transition = 'opacity 500ms ease-out';
            requestAnimationFrame(() => {
              (band as SVGElement).style.opacity = '1';
            });
          }
        }
      }

      // All-bankrupt notice
      if (result.bankruptcyRate >= 1) {
        const bankruptRound = result.medianTrajectory.findIndex(v => v <= 0.01);
        const notice = document.createElement('div');
        notice.className = 'sim-chart-notice';
        notice.textContent = `All paths bankrupt by bet ${bankruptRound > 0 ? bankruptRound : rounds}`;
        chartWealthEl.appendChild(notice);
      }

      chartWealthCaption.textContent =
        `Figure 2 - Median bankroll trajectory, with 10th to 90th percentile band, across ${intlSim.format(config.paths)} paths.`;
    }

    // ─── Chart: Kelly curve (Figure 1, analytical) ───

    function renderKellyCurve(): void {
      const width = chartKellyEl.clientWidth || 600;
      const p = parseInt(simPSlider.value) / 1000;
      const b = sliderToSimB(parseInt(simBSlider.value));
      const kfRaw = kellyFraction(p, b);
      const isNegativeEdge = kfRaw <= 0;
      const kelly = Math.abs(kfRaw);

      const data: { mult: number; growth: number; pos: number; neg: number }[] = [];
      for (let m = 0; m <= 2.5; m += 0.005) {
        const f = kelly * m;
        let g: number;
        if (f <= 0) g = 0;
        else if (f >= 0.999) g = -0.5;
        else {
          g = growthRate(f, p, b);
          if (g < -0.5) g = -0.5;
        }
        data.push({
          mult: Math.round(m * 1000) / 1000,
          growth: g,
          pos: Math.max(0, g),
          neg: Math.min(0, g),
        });
      }

      const tickMults = [0, 0.5, 1, 1.5, 2, 2.5];

      // Conditional marks for positive-edge scenarios only
      const positiveEdgeMarks: any[] = [];
      if (!isNegativeEdge) {
        const peakGrowth = growthRate(kelly, p, b);
        positiveEdgeMarks.push(
          Plot.dot([{ x: 1, y: peakGrowth }], { x: "x", y: "y", fill: "#a8252c", r: 4 }),
          Plot.text([{ x: 1, y: peakGrowth }], { x: "x", y: "y", text: ["Full Kelly"], dy: -14, fill: "#a8252c", fontSize: 12, fontWeight: "600" }),
          Plot.ruleX([simKellyMult], { stroke: "#a8252c", strokeWidth: 1.5, strokeDasharray: "4,3" }),
        );
        // £ amount labels
        positiveEdgeMarks.push(Plot.text(tickMults.map(m => ({
          mult: m,
          label: formatCurrency(Math.round(kelly * m * simBankroll)),
        })), {
          x: "mult", y: null, text: "label",
          frameAnchor: "bottom", dy: 38, fontSize: 10, fontWeight: "600",
          fontFamily: '"JetBrains Mono", monospace', fill: "#1a1a1a",
        }));
      } else {
        // Negative-edge annotation
        const yMid = (Math.min(...data.map(d => d.growth)) + 0) / 2;
        positiveEdgeMarks.push(Plot.text([{ x: 1.25, y: yMid }], {
          x: "x", y: "y",
          text: ["Kelly says don't play.\nEvery bet size shrinks your bankroll."],
          fontSize: 13, fontStyle: "italic", fill: "#1a1a1a", lineWidth: 20,
        }));
      }

      const chart = Plot.plot({
        width,
        height: 240,
        marginBottom: isNegativeEdge ? 30 : 52,
        style: {
          fontFamily: '"EB Garamond", Georgia, serif',
          fontSize: '13px',
          background: 'transparent',
        },
        x: {
          label: "Kelly multiplier",
          domain: [0, 2.5],
          ticks: tickMults,
          tickFormat: (d: number) => d.toFixed(1) + '×',
        },
        y: { label: "↑ Growth rate (per round)", grid: true },
        marks: [
          Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
          Plot.areaY(data, { x: "mult", y: "pos", fill: "#a8252c", fillOpacity: 0.08, curve: "natural" }),
          Plot.areaY(data, { x: "mult", y: "neg", fill: "#6b7f5e", fillOpacity: 0.08, curve: "natural" }),
          Plot.ruleY([0], { stroke: "#1a1a1a", strokeOpacity: 0.15 }),
          Plot.lineY(data, { x: "mult", y: "growth", stroke: "#1a1a1a", strokeWidth: 2, curve: "natural" }),
          ...positiveEdgeMarks,
        ],
      });

      chartKellyEl.innerHTML = '';
      chartKellyEl.appendChild(chart);
    }

    // ─── Stats with animated tweening ───

    function tweenStats(result: SimResult): void {
      const targets = {
        median: Math.round(result.medianFinal),
        mean: Math.round(result.meanFinal),
        bankrupt: result.bankruptcyRate * 100,
        beat: result.beatStartRate * 100,
      };

      if (simReducedMotion || !hasRunOnce) {
        statMedian.innerHTML = formatCurrency(targets.median);
        statMean.innerHTML = formatCurrency(targets.mean);
        statBankrupt.textContent = targets.bankrupt.toFixed(1) + '%';
        statBeat.textContent = targets.beat.toFixed(1) + '%';
        prevStats = targets;
        hasRunOnce = true;
        return;
      }

      const starts = { ...prevStats };
      const duration = 700;
      const startTime = performance.now();

      function tick(now: number): void {
        const elapsed = now - startTime;
        const t = Math.min(elapsed / duration, 1);
        const ease = 1 - Math.pow(1 - t, 3);

        const curMedian = starts.median + (targets.median - starts.median) * ease;
        const curMean = starts.mean + (targets.mean - starts.mean) * ease;
        const curBankrupt = starts.bankrupt + (targets.bankrupt - starts.bankrupt) * ease;
        const curBeat = starts.beat + (targets.beat - starts.beat) * ease;

        statMedian.innerHTML = formatCurrency(Math.round(curMedian));
        statMean.innerHTML = formatCurrency(Math.round(curMean));
        statBankrupt.textContent = curBankrupt.toFixed(1) + '%';
        statBeat.textContent = curBeat.toFixed(1) + '%';

        if (t < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
      prevStats = targets;
      hasRunOnce = true;
    }

    // ─── Run simulation ───

    let runLocked = false;

    function setRunningState(on: boolean): void {
      if (on) {
        simRunBtn.style.background = '#888';
        // Dim active scenario and strategy buttons
        document.querySelectorAll('.scenario-btn.is-active, [data-kelly-mult].is-active').forEach(el => {
          (el as HTMLElement).style.boxShadow = '0 0 0 1px rgba(176,141,44,0.4)';
          (el as HTMLElement).style.filter = 'brightness(0.92)';
        });
      } else {
        simRunBtn.style.background = '';
        document.querySelectorAll('.scenario-btn.is-active, [data-kelly-mult].is-active').forEach(el => {
          (el as HTMLElement).style.boxShadow = '';
          (el as HTMLElement).style.filter = '';
        });
      }
    }

    async function doRun(): Promise<void> {
      if (runLocked) return;
      runLocked = true;
      simRunBtn.textContent = 'Running…';
      simRunBtn.disabled = true;
      setRunningState(true);
      const runStartTime = performance.now();

      await new Promise<void>(r => requestAnimationFrame(() => requestAnimationFrame(() => r())));

      const config = getSimConfig();
      track('s3_simulation_run');
      const result = runSimulation(config);

      renderWealthChart(result, config);
      renderKellyCurve();
      tweenStats(result);

      const elapsed = performance.now() - runStartTime;
      const remaining = Math.max(0, 300 - elapsed);
      const reEnableDelay = simReducedMotion ? remaining : Math.max(remaining, 700);

      setTimeout(() => {
        simRunBtn.textContent = 'Run simulation';
        simRunBtn.disabled = false;
        setRunningState(false);
        runLocked = false;
      }, reEnableDelay);
    }

    simRunBtn.addEventListener('click', doRun);

    // ─── Reset ───

    simResetLink.addEventListener('click', (e) => {
      e.preventDefault();
      simBankroll = 1000;
      simKellyMult = 1.0;
      simRoundsSlider.value = '500';
      simPSlider.value = '550';
      simBSlider.value = '1000';

      document.querySelectorAll('[data-bankroll]').forEach(b => {
        b.classList.toggle('is-active', (b as HTMLElement).dataset.bankroll === '1000');
      });
      document.querySelectorAll('[data-kelly-mult]').forEach(b => {
        b.classList.toggle('is-active', (b as HTMLElement).dataset.kellyMult === '1');
      });

      updateAllReadouts();
      clearScenarioPreset();
      updateKellyDisplay();

      chartWealthEl.innerHTML = '<div class="sim-chart-placeholder"><span class="text-card-red" style="font-size: 1.4rem; display: block; margin-bottom: 0.4rem;">♠</span><span style="font-variant: small-caps; font-style: italic;">Run the simulation to see the result</span></div>';
      statMedian.textContent = '-';
      statMean.textContent = '-';
      statBankrupt.textContent = '-';
      statBeat.textContent = '-';
      prevStats = { median: 0, mean: 0, bankrupt: 0, beat: 0 };
      hasRunOnce = false;

      renderKellyCurve();
    });

    // ─── Scenario presets ───

    interface Scenario { bankroll: number; rounds: number; p: number; b: number; }

    const scenarios: Record<string, Scenario> = {
      'fair-coin':       { bankroll: 1000,       rounds: 500,  p: 0.50,   b: 1 },
      'eu-roulette':     { bankroll: 1000,       rounds: 500,  p: 0.4865, b: 1 },
      'us-roulette':     { bankroll: 1000,       rounds: 500,  p: 0.4737, b: 1 },
      'biased-coin':     { bankroll: 1000,       rounds: 500,  p: 0.55,   b: 1 },
      'card-counter':    { bankroll: 100_000,    rounds: 2000, p: 0.51,   b: 1 },
      'sports-gambler':  { bankroll: 100_000,    rounds: 1000, p: 0.54,   b: 0.909 },
      'pre-seed-vc':     { bankroll: 10_000_000, rounds: 40,   p: 0.1,    b: 20 },
      'growth-vc':       { bankroll: 100_000_000,rounds: 25,   p: 0.3,    b: 3 },
      'private-equity':  { bankroll: 100_000_000,rounds: 15,   p: 0.85,   b: 1.5 },
    };

    document.querySelectorAll<HTMLButtonElement>('[data-scenario]').forEach(btn => {
      const key = btn.dataset.scenario!;
      if (!scenarios[key]) return;

      btn.addEventListener('click', () => {
        const s = scenarios[key];
        simBankroll = s.bankroll;
        document.querySelectorAll('[data-bankroll]').forEach(b => {
          b.classList.toggle('is-active', (b as HTMLElement).dataset.bankroll === String(s.bankroll));
        });
        simRoundsSlider.value = String(s.rounds);
        simPSlider.value = String(Math.round(s.p * 1000));
        simBSlider.value = String(Math.round(simBToSlider(s.b)));
        updateAllReadouts();
        renderKellyCurve();
        updateKellyDisplay();

        clearScenarioPreset();
        btn.classList.add('is-active');

        doRun();
      });
    });

    // Scroll link
    document.getElementById('scroll-to-s4')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('kelly')?.scrollIntoView({ behavior: 'smooth' });
    });

    // Initial render
    renderKellyCurve();
    updateKellyDisplay();

    // ─── Expose p/b for Section 4 ───
    (window as any).__s3GetPB = () => ({
      p: parseInt(simPSlider.value) / 1000,
      b: sliderToSimB(parseInt(simBSlider.value)),
    });
  </script>

  <script>
    // ─── Section 4: Full Kelly vs Half Kelly ───
    import * as Plot from "@observablehq/plot";
    import { formatCurrency } from "../lib/format";
    import { track as s4Track } from '../lib/analytics';

    let s4SliderEngaged = false;

    const s4ErrorSlider = document.getElementById('s4-error-slider') as HTMLInputElement;
    const s4ErrorReadout = document.getElementById('s4-error-readout')!;
    const s4ZoneLabel = document.getElementById('s4-zone-label')!;
    const chartS4El = document.getElementById('chart-s4-error')!;
    const s4FullWealth = document.getElementById('s4-full-wealth')!;
    const s4HalfWealth = document.getElementById('s4-half-wealth')!;
    const s4FullMult = document.getElementById('s4-full-mult')!;
    const s4HalfMult = document.getElementById('s4-half-mult')!;
    const s4Commentary = document.getElementById('s4-commentary')!;

    function getS4PB(): { p: number; b: number } {
      const getter = (window as any).__s3GetPB;
      if (getter) return getter();
      return { p: 0.55, b: 1 };
    }

    function computeGrowth(fBet: number, pTrue: number, b: number): number {
      if (fBet <= 0) return 0;
      if (fBet >= 1) fBet = 0.999;
      const qTrue = 1 - pTrue;
      return pTrue * Math.log(1 + fBet * b) + qTrue * Math.log(1 - fBet);
    }

    function getZone(v: number): { label: string; color: string; bold: boolean } {
      if (v <= -30) return { label: 'Very underconfident', color: '#6b7f5e', bold: false };
      if (v <= -10) return { label: 'Underconfident', color: '#6b7f5e', bold: false };
      if (v < 10) return { label: 'Spot on', color: '#1a1a1a', bold: false };
      if (v < 30) return { label: 'Overconfident', color: '#a8252c', bold: false };
      return { label: 'Very overconfident', color: '#a8252c', bold: true };
    }

    function renderS4Chart(): void {
      const { p, b } = getS4PB();
      const edgeTrue = b * p - (1 - p);
      const currentError = parseInt(s4ErrorSlider.value);

      const data: { error: number; full: number; half: number }[] = [];
      for (let ePct = -50; ePct <= 50; ePct++) {
        const e = ePct / 100;
        const edgeEst = edgeTrue * (1 + e);
        let fEst = edgeEst > 0 ? edgeEst / b : 0;
        if (fEst > 1) fEst = 1;
        data.push({
          error: ePct,
          full: computeGrowth(fEst, p, b),
          half: computeGrowth(fEst / 2, p, b),
        });
      }

      const negData = data.filter(d => d.full < 0).map(d => ({ error: d.error, neg: d.full }));
      const width = chartS4El.clientWidth || 600;

      // Compute y-domain from actual data with 15% padding
      const allVals = data.flatMap(d => [d.full, d.half]);
      const yMin = Math.min(...allVals);
      const yMax = Math.max(...allVals);
      const yPad = (yMax - yMin) * 0.15 || 0.001;
      const yDomain: [number, number] = [yMin - yPad, yMax + yPad];

      const chart = Plot.plot({
        width,
        height: 280,
        marginBottom: 8,
        marginLeft: 60,
        marginRight: 20,
        style: {
          fontFamily: '"EB Garamond", Georgia, serif',
          fontSize: '13px',
          background: 'transparent',
        },
        x: { label: null, domain: [-50, 50], axis: null },
        y: { label: "↑ Growth rate (per bet)", grid: true, domain: yDomain },
        marks: [
          // Zone shading - use computed y domain
          Plot.rect([{ x1: 0, x2: 50 }], {
            x1: "x1", x2: "x2", y1: yDomain[0], y2: yDomain[1],
            fill: "#a8252c", fillOpacity: 0.04,
          }),
          Plot.rect([{ x1: -50, x2: 0 }], {
            x1: "x1", x2: "x2", y1: yDomain[0], y2: yDomain[1],
            fill: "#6b7f5e", fillOpacity: 0.04,
          }),
          Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
          Plot.ruleY([0], { stroke: "#1a1a1a", strokeOpacity: 0.15 }),
          ...(negData.length > 0 ? [Plot.areaY(negData, { x: "error", y: "neg", fill: "#6b7f5e", fillOpacity: 0.1, curve: "natural" })] : []),
          Plot.lineY(data, { x: "error", y: "full", stroke: "#a8252c", strokeWidth: 2.5, curve: "natural" }),
          Plot.lineY(data, { x: "error", y: "half", stroke: "#1a1a1a", strokeWidth: 2, curve: "natural" }),
          Plot.ruleX([currentError], { stroke: "#a8252c", strokeWidth: 1.5, strokeDasharray: "4,3" }),
          Plot.text([{ x: -40, y: computeGrowth(Math.max(0, edgeTrue * 0.6 / b), p, b) }], {
            x: "x", y: "y", text: ["Full Kelly"], fill: "#a8252c", fontSize: 12, fontWeight: "600", dy: -10,
          }),
          Plot.text([{ x: -40, y: computeGrowth(Math.max(0, edgeTrue * 0.6 / b) / 2, p, b) }], {
            x: "x", y: "y", text: ["Half Kelly"], fill: "#1a1a1a", fontSize: 12, fontWeight: "600", dy: -10,
          }),
        ],
      });

      chartS4El.innerHTML = '';
      chartS4El.appendChild(chart);

      // Align slider to chart's plot area
      const sliderWrap = document.getElementById('s4-slider-wrap')!;
      sliderWrap.style.paddingLeft = '60px';
      sliderWrap.style.paddingRight = '20px';

      updateS4Readouts();
    }

    function updateS4Readouts(): void {
      const { p, b } = getS4PB();
      const edgeTrue = b * p - (1 - p);
      const errVal = parseInt(s4ErrorSlider.value);
      const e = errVal / 100;
      const edgeEst = edgeTrue * (1 + e);
      let fEst = edgeEst > 0 ? edgeEst / b : 0;
      if (fEst > 1) fEst = 1;

      const gFull = computeGrowth(fEst, p, b);
      const gHalf = computeGrowth(fEst / 2, p, b);

      // Wealth after 500 bets
      const wFull = gFull <= -1 ? 0 : Math.max(0, 1000 * Math.exp(gFull * 500));
      const wHalf = gHalf <= -1 ? 0 : Math.max(0, 1000 * Math.exp(gHalf * 500));

      s4FullWealth.innerHTML = wFull < 1 ? '£0' : formatCurrency(Math.round(wFull));
      s4FullWealth.style.color = wFull < 1000 ? '#a8252c' : '';
      s4FullMult.textContent = wFull < 1 ? '(bankrupt)' : `(${(wFull / 1000).toFixed(1)}× starting bankroll)`;
      s4FullMult.style.color = wFull < 1000 ? '#a8252c' : '';

      s4HalfWealth.innerHTML = wHalf < 1 ? '£0' : formatCurrency(Math.round(wHalf));
      s4HalfWealth.style.color = wHalf < 1000 ? '#a8252c' : '';
      s4HalfMult.textContent = wHalf < 1 ? '(bankrupt)' : `(${(wHalf / 1000).toFixed(1)}× starting bankroll)`;
      s4HalfMult.style.color = wHalf < 1000 ? '#a8252c' : '';

      // Commentary
      if (wFull < 1000 && wHalf < 1000) {
        s4Commentary.textContent = 'Both strategies are losing money at this level of error.';
      } else if (wFull < 1000) {
        s4Commentary.textContent = 'Full Kelly is losing you money. Half Kelly is still growing.';
      } else if (wHalf > wFull * 1.2) {
        s4Commentary.textContent = 'Half Kelly is winning.';
      } else if (wFull > wHalf * 1.2) {
        s4Commentary.textContent = 'Full Kelly is winning.';
      } else {
        s4Commentary.textContent = 'Full Kelly and Half Kelly are roughly tied.';
      }

      // Slider readout + zone
      s4ErrorReadout.textContent = errVal === 0 ? '0%' : (errVal > 0 ? '+' : '') + errVal + '%';
      const zone = getZone(errVal);
      s4ZoneLabel.textContent = zone.label;
      s4ZoneLabel.style.color = zone.color;
      s4ZoneLabel.style.fontWeight = zone.bold ? '700' : '';
    }

    s4ErrorSlider.addEventListener('input', () => {
      if (!s4SliderEngaged) {
        s4SliderEngaged = true;
        s4Track('s4_slider_engaged');
      }
      renderS4Chart();
    });

    document.getElementById('scroll-to-s5')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('ruin')?.scrollIntoView({ behavior: 'smooth' });
    });

    document.querySelectorAll('[data-scenario]').forEach(btn => {
      btn.addEventListener('click', () => setTimeout(renderS4Chart, 50));
    });
    document.getElementById('sim-p')?.addEventListener('input', () => setTimeout(renderS4Chart, 10));
    document.getElementById('sim-b')?.addEventListener('input', () => setTimeout(renderS4Chart, 10));

    renderS4Chart();
  </script>

  <script>
    // ─── Section 5: Gambler's Ruin ───
    import * as Plot from "@observablehq/plot";
    import { track as s5Track } from '../lib/analytics';

    // ─── Part 1: Mirror question ───

    const s5Slider = document.getElementById('s5-bet-slider') as HTMLInputElement;
    const s5Readout = document.getElementById('s5-bet-readout')!;
    const s5LockBtn = document.getElementById('s5-lock-bet') as HTMLButtonElement;
    const s5BtnContainer = document.getElementById('s5-button-container')!;
    const s5ResponsePanel = document.getElementById('s5-response-panel')!;
    const s5ResponseText = document.getElementById('s5-response-text')!;
    const s5Nudge = document.getElementById('s5-nudge')!;

    s5Slider.addEventListener('input', () => {
      s5Readout.textContent = `£${s5Slider.value}`;
      s5Slider.setAttribute('aria-valuenow', s5Slider.value);
      s5Slider.setAttribute('aria-valuetext', `£${s5Slider.value}`);
    });

    s5LockBtn.addEventListener('click', () => {
      const x = parseInt(s5Slider.value, 10);
      s5Slider.disabled = true;

      s5BtnContainer.innerHTML =
        '<a href="#" id="s5-change-answer" class="text-sm text-ink/40 hover:text-ink/60" style="text-decoration: none; font-style: italic;">Change my answer</a>';

      document.getElementById('s5-change-answer')!.addEventListener('click', (e) => {
        e.preventDefault();
        s5Slider.disabled = false;
        s5ResponsePanel.classList.remove('is-visible');
        s5Nudge.style.display = 'none';
        s5BtnContainer.innerHTML = '';
        s5BtnContainer.appendChild(s5LockBtn);
      });

      const ruinLink = '<a href="https://en.wikipedia.org/wiki/Gambler%27s_ruin" target="_blank" rel="noopener noreferrer" class="text-gold">ruin</a>';

      let msg: string;
      if (x === 0) {
        msg = `Correct. With zero edge, every positive bet size leads to ${ruinLink} given enough time, assuming you have finite money. This is gambler's ruin - and the simulator below shows why. Kelly agrees: plug p=0.5 and b=1 into the formula and it returns exactly zero.`;
      } else if (x <= 50) {
        msg = `You picked £${x}. Wrong - but understandably so. A small bet feels safe, but with zero edge, any positive bet size leads to ${ruinLink} eventually if you have finite money. Kelly's answer here is £0. The simulator below shows why.`;
      } else if (x <= 500) {
        msg = `You picked £${x}. Wrong. With a fair coin paying even money, there is no bet size that leads to long-term gain. Every positive stake feeds the same fundamental problem: given finite money and enough time, you go broke. Kelly's answer here is £0. Play with the simulator below.`;
      } else {
        msg = `You picked £${x}. Wrong, and bold. On a fair coin, there is no bet size that works. The larger the bet, the faster the ${ruinLink}. Kelly's answer here is £0. The simulator below shows what happens at different bet sizes.`;
      }

      s5ResponseText.innerHTML = msg;

      requestAnimationFrame(() => {
        s5ResponsePanel.classList.add('is-visible');
        s5Nudge.style.display = '';
      });
    });

    document.getElementById('s5-scroll-sim')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('s5-simulator')?.scrollIntoView({ behavior: 'smooth' });
    });

    // ─── Part 3: Ruin simulator ───

    const S5_BANKROLL = 1000;
    const S5_PATHS = 1000;
    const S5_MAX_ROUNDS = 10000;
    const S5_SAMPLE_COUNT = 25;

    let s5TargetMult = 2;

    const s5RunBtn = document.getElementById('s5-run') as HTMLButtonElement;
    const s5TrajectoryEl = document.getElementById('s5-trajectory-chart')!;
    const s5BarEl = document.getElementById('s5-bar-chart')!;
    const s5TheoryLine = document.getElementById('s5-theory-line')!;
    const s5Asymmetry = document.getElementById('s5-asymmetry')!;
    const s5AsymmetryText = document.getElementById('s5-asymmetry-text')!;
    const s5Orient = document.getElementById('s5-orient')!;

    const s5PSlider = document.getElementById('s5-p-slider') as HTMLInputElement;
    const s5PReadout = document.getElementById('s5-p-readout')!;
    const s5BetSizeSlider = document.getElementById('s5-bet-size-slider') as HTMLInputElement;
    const s5BetSizeReadout = document.getElementById('s5-betsize-readout')!;

    s5PSlider.addEventListener('input', () => {
      s5PReadout.textContent = (parseInt(s5PSlider.value) / 10).toFixed(1) + '%';
    });
    s5BetSizeSlider.addEventListener('input', () => {
      s5BetSizeReadout.textContent = '£' + s5BetSizeSlider.value;
    });

    function updateS5Orient(): void {
      const target = S5_BANKROLL * s5TargetMult;
      s5Orient.textContent = `You have £1,000. Target: £${target.toLocaleString('en-GB')}. How do you get there?`;
    }

    // Target buttons
    document.querySelectorAll<HTMLButtonElement>('[data-s5-target]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-s5-target]').forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        s5TargetMult = parseFloat(btn.dataset.s5Target!);
        updateS5Orient();
      });
    });

    // Simulation
    interface RuinPath {
      trajectory: number[];
      outcome: 'target' | 'ruin' | 'unresolved';
    }

    interface RuinResult {
      paths: RuinPath[];
      hitTarget: number;
      hitRuin: number;
      unresolved: number;
    }

    function runRuinSim(): RuinResult {
      const target = S5_BANKROLL * s5TargetMult;
      const p = parseInt(s5PSlider.value) / 1000;
      const bet = parseInt(s5BetSizeSlider.value);

      const paths: RuinPath[] = [];
      let hitTarget = 0;
      let hitRuin = 0;
      let unresolved = 0;

      for (let i = 0; i < S5_PATHS; i++) {
        const traj: number[] = [S5_BANKROLL];
        let bankroll = S5_BANKROLL;
        let outcome: 'target' | 'ruin' | 'unresolved' = 'unresolved';

        for (let r = 0; r < S5_MAX_ROUNDS; r++) {
          bankroll += Math.random() < p ? bet : -bet;
          traj.push(bankroll);
          if (bankroll >= target) { outcome = 'target'; hitTarget++; break; }
          if (bankroll <= 0) { outcome = 'ruin'; hitRuin++; break; }
        }
        if (outcome === 'unresolved') unresolved++;
        paths.push({ trajectory: traj, outcome });
      }

      return { paths, hitTarget, hitRuin, unresolved };
    }

    function analyticRuinProb(): number {
      const target = S5_BANKROLL * s5TargetMult;
      const p = parseInt(s5PSlider.value) / 1000;
      const q = 1 - p;
      const bet = parseInt(s5BetSizeSlider.value);
      const n = Math.round(S5_BANKROLL / bet);
      const m = Math.round(target / bet);

      if (Math.abs(p - 0.5) < 0.0001) return 1 - n / m;
      const ratio = q / p;
      return (1 - Math.pow(ratio, n)) / (1 - Math.pow(ratio, m));
    }

    const OUTCOME_COLORS: Record<string, string> = {
      ruin: '#a8252c',
      target: '#2d7a3f',
      unresolved: '#666666',
    };
    const OUTCOME_OPACITY: Record<string, number> = {
      ruin: 0.4,
      target: 0.4,
      unresolved: 0.3,
    };

    function renderTrajectoryChart(result: RuinResult): void {
      const target = S5_BANKROLL * s5TargetMult;
      const width = s5TrajectoryEl.clientWidth || 600;

      // Pick 25 random sample paths
      const pool = [...Array(result.paths.length).keys()];
      for (let i = pool.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [pool[i], pool[j]] = [pool[j], pool[i]];
      }
      const indices = pool.slice(0, S5_SAMPLE_COUNT);

      // Build separate line data per outcome for colouring
      const ruinLines: { round: number; bankroll: number; path: number }[] = [];
      const targetLines: { round: number; bankroll: number; path: number }[] = [];
      const unresolvedLines: { round: number; bankroll: number; path: number }[] = [];

      let maxRound = 0;
      for (const idx of indices) {
        const { trajectory, outcome } = result.paths[idx];
        if (trajectory.length > maxRound) maxRound = trajectory.length;
        const dest = outcome === 'ruin' ? ruinLines : outcome === 'target' ? targetLines : unresolvedLines;
        for (let r = 0; r < trajectory.length; r++) {
          dest.push({ round: r, bankroll: trajectory[r], path: idx });
        }
      }

      const marks: any[] = [
        Plot.gridY({ stroke: "#1a1a1a", strokeOpacity: 0.06 }),
        Plot.ruleY([target], { stroke: "#1a1a1a", strokeDasharray: "6,4", strokeOpacity: 0.4 }),
        Plot.text([{ x: maxRound * 0.95, y: target }], {
          x: "x", y: "y", text: ["Target"], dy: -10, fontSize: 11, fill: "#1a1a1a", textAnchor: "end",
        }),
        Plot.text([{ x: 0, y: 0 }], {
          x: "x", y: "y", text: ["Ruin"], dx: 25, dy: -8, fontSize: 11, fill: "#a8252c",
        }),
      ];

      if (ruinLines.length > 0) {
        marks.push(Plot.line(ruinLines, { x: "round", y: "bankroll", z: "path", stroke: OUTCOME_COLORS.ruin, strokeOpacity: OUTCOME_OPACITY.ruin, strokeWidth: 1.2 }));
      }
      if (unresolvedLines.length > 0) {
        marks.push(Plot.line(unresolvedLines, { x: "round", y: "bankroll", z: "path", stroke: OUTCOME_COLORS.unresolved, strokeOpacity: OUTCOME_OPACITY.unresolved, strokeWidth: 1.2 }));
      }
      if (targetLines.length > 0) {
        marks.push(Plot.line(targetLines, { x: "round", y: "bankroll", z: "path", stroke: OUTCOME_COLORS.target, strokeOpacity: OUTCOME_OPACITY.target, strokeWidth: 1.2 }));
      }

      const chart = Plot.plot({
        width,
        height: 280,
        style: { fontFamily: '"EB Garamond", Georgia, serif', fontSize: '13px', background: 'transparent' },
        x: { label: "Round", domain: [0, maxRound] },
        y: { label: "↑ Bankroll (£)", domain: [0, target * 1.1] },
        marks,
      });

      s5TrajectoryEl.innerHTML = '';
      s5TrajectoryEl.appendChild(chart);
    }

    function renderSummaryBar(hitTarget: number, hitRuin: number, unresolvedCount: number): void {
      const total = hitTarget + hitRuin + unresolvedCount;
      const pctRuin = hitRuin / total * 100;
      const pctUnresolved = unresolvedCount / total * 100;
      const pctTarget = hitTarget / total * 100;

      s5BarEl.style.display = '';

      const bar = document.createElement('div');
      bar.style.cssText = 'display: flex; height: 36px; border-radius: 4px; overflow: hidden; font-family: "JetBrains Mono", monospace; font-size: 0.7rem; font-weight: 600;';

      if (pctRuin > 0) {
        const seg = document.createElement('div');
        seg.style.cssText = `width: ${pctRuin}%; background: #a8252c; color: #fafaf7; display: flex; align-items: center; justify-content: center;`;
        if (pctRuin > 8) seg.textContent = pctRuin.toFixed(1) + '%';
        bar.appendChild(seg);
      }
      if (pctUnresolved > 0) {
        const seg = document.createElement('div');
        seg.style.cssText = `width: ${pctUnresolved}%; background: #666; color: #fafaf7; display: flex; align-items: center; justify-content: center;`;
        if (pctUnresolved > 8) seg.textContent = pctUnresolved.toFixed(1) + '%';
        bar.appendChild(seg);
      }
      if (pctTarget > 0) {
        const seg = document.createElement('div');
        seg.style.cssText = `width: ${pctTarget}%; background: #2d7a3f; color: #fafaf7; display: flex; align-items: center; justify-content: center;`;
        if (pctTarget > 8) seg.textContent = pctTarget.toFixed(1) + '%';
        bar.appendChild(seg);
      }

      s5BarEl.innerHTML = '';
      s5BarEl.appendChild(bar);

      // Theory vs simulation
      const aRuin = analyticRuinProb();
      const aRuinPct = aRuin * 100;
      const simRuinPct = pctRuin;
      const diff = Math.abs(aRuinPct - simRuinPct);
      let theoryText = `Theory predicts ruin in ${aRuinPct.toFixed(1)}% of cases. `;
      if (diff <= 2) {
        theoryText += 'The simulation agrees.';
      } else {
        theoryText += `The simulation disagrees by ${diff.toFixed(1)}%.`;
      }
      s5TheoryLine.textContent = theoryText;
      s5TheoryLine.style.display = '';

      // Asymmetry callout
      const target = S5_BANKROLL * s5TargetMult;
      const profit = target - S5_BANKROLL;
      s5AsymmetryText.textContent = `If you hit your target, you make £${profit.toLocaleString('en-GB')}. If you go broke, you lose £1,000.`;
      s5Asymmetry.style.display = '';
    }

    async function doS5Run(): Promise<void> {
      s5RunBtn.textContent = 'Running…';
      s5RunBtn.disabled = true;

      await new Promise<void>(r => requestAnimationFrame(() => requestAnimationFrame(() => r())));

      s5Track('s5_simulation_run');
      const result = runRuinSim();

      renderTrajectoryChart(result);
      renderSummaryBar(result.hitTarget, result.hitRuin, result.unresolved);

      setTimeout(() => {
        s5RunBtn.textContent = 'Run simulation';
        s5RunBtn.disabled = false;
      }, 300);
    }

    s5RunBtn.addEventListener('click', doS5Run);

    document.getElementById('scroll-to-s6')?.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('beyond')?.scrollIntoView({ behavior: 'smooth' });
    });

    updateS5Orient();
  </script>
</Base>
