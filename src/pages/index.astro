        </div>

        <figure class="mb-0">
          <div id="chart-s4-error" class="sim-chart-container" role="img" aria-label="Growth rate when edge estimate is wrong, comparing Full Kelly vs Half Kelly" style="margin-bottom: 0;"></div>
        </figure>

        <div id="s4-slider-wrap" style="padding: 0;">
          <input type="range" id="s4-error-slider" min="-50" max="50" step="1" value="0" style="margin: 0;" />
