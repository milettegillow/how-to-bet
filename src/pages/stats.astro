---
export const prerender = false;

import Base from '../layouts/Base.astro';
import '../styles/global.css';
import { Redis } from '@upstash/redis';

// ─── Read KV data ───

let kvConfigured = true;
let data = {
  visitors: 0,
  visitorsToday: 0,
  avgTimeMs: 0,
  sessionCountWithTime: 0,
  scrolledToBottom: 0,
  // Section-specific
  s1Sessions: 0,
  s2Sessions: 0,
  s3Total: 0,
  s3Sessions: 0,
  s4Sessions: 0,
  s5Total: 0,
  s5Sessions: 0,
  anySimSessions: 0,
};

try {
  const url = import.meta.env.KV_REST_API_URL || import.meta.env.UPSTASH_REDIS_REST_URL;
  const token = import.meta.env.KV_REST_API_TOKEN || import.meta.env.UPSTASH_REDIS_REST_TOKEN;

  if (!url || !token) {
    kvConfigured = false;
  } else {
    const redis = new Redis({ url, token });
    const today = new Date().toISOString().slice(0, 10);

    const results = await Promise.all([
      redis.get<number>('alltime:visitors'),
      redis.get<number>(`daily:${today}:visitors`),
      redis.get<number>('alltime:total_time_ms'),
      redis.get<number>('alltime:session_count_with_time'),
      redis.get<number>('alltime:scrolled_to_bottom'),
      // Section-specific
      redis.get<number>('alltime:s1_bet_locked:sessions'),
      redis.get<number>('alltime:s2_preset_clicked:sessions'),
      redis.get<number>('alltime:s3_simulation_run:total'),
      redis.get<number>('alltime:s3_simulation_run:sessions'),
      redis.get<number>('alltime:s4_slider_engaged:sessions'),
      redis.get<number>('alltime:s5_simulation_run:total'),
      redis.get<number>('alltime:s5_simulation_run:sessions'),
      redis.get<number>('alltime:any_simulation:sessions'),
    ]);

    const n = (v: number | null) => Number(v) || 0;
    const nSessionCount = n(results[3]);
    const nTotalTimeMs = n(results[2]);

    data = {
      visitors: n(results[0]),
      visitorsToday: n(results[1]),
      avgTimeMs: nSessionCount > 0 ? nTotalTimeMs / nSessionCount : 0,
      sessionCountWithTime: nSessionCount,
      scrolledToBottom: n(results[4]),
      s1Sessions: n(results[5]),
      s2Sessions: n(results[6]),
      s3Total: n(results[7]),
      s3Sessions: n(results[8]),
      s4Sessions: n(results[9]),
      s5Total: n(results[10]),
      s5Sessions: n(results[11]),
      anySimSessions: n(results[12]),
    };
  }
} catch (err) {
  console.error('[stats] Redis error:', err);
  kvConfigured = false;
}

// ─── Format helpers ───

function formatTime(ms: number): string {
  const totalSeconds = Math.round(ms / 1000);
  if (totalSeconds < 60) return `${totalSeconds} seconds`;
  const minutes = Math.floor(totalSeconds / 60);
  const seconds = totalSeconds % 60;
  return `${minutes}:${seconds.toString().padStart(2, '0')}`;
}

const fmt = (n: number) => n.toLocaleString('en-GB');

const totalSimRuns = data.s3Total + data.s5Total;
const avgRunsPerRunner = data.anySimSessions > 0
  ? (totalSimRuns / data.anySimSessions).toFixed(1)
  : '0';

const s3Avg = data.s3Sessions > 0 ? (data.s3Total / data.s3Sessions).toFixed(1) : '0';
const s5Avg = data.s5Sessions > 0 ? (data.s5Total / data.s5Sessions).toFixed(1) : '0';

const scrollPct = data.sessionCountWithTime > 0
  ? ((data.scrolledToBottom / data.sessionCountWithTime) * 100).toFixed(1)
  : '0';

const now = new Date().toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
---

<Base title="Stats - How to bet (and win)">
  <main class="px-4 sm:px-6">
    <div class="max-w-prose mx-auto pt-20 pb-16 sm:pt-28 sm:pb-20">
      <div class="flex items-start gap-4 mb-8">
        <img src="/chip-1.png" alt="" width="48" height="48" class="section-chip-img hidden sm:block" />
        <h1 class="text-ink">Stats</h1>
      </div>
      <p class="mt-3 text-ink/60 italic" style="font-size: 1.05rem;">
        Live engagement data for betting.milettegillow.com. Updated in real time. No cookies, no third-party tracking.
      </p>

      {!kvConfigured ? (
        <div class="mt-12 text-center py-12 border border-ink/10 rounded" style="background: #f8f7f4;">
          <p class="text-ink/40 italic">Storage not yet configured.</p>
          <p class="text-sm text-ink/30 mt-2">Install Upstash for Redis from Vercel Storage > Marketplace.</p>
        </div>
      ) : (
        <div class="mt-12">
          {/* Unique visitors */}
          <div class="readout-card mb-4" style="padding: 1.5rem;">
            <div class="readout-label">Unique visitors</div>
            <div class="readout-value" style="font-size: 2rem;">{fmt(data.visitors)}</div>
            <div class="readout-caption">{fmt(data.visitorsToday)} today</div>
          </div>

          {/* Average time on site */}
          <div class="readout-card mb-4" style="padding: 1.5rem;">
            <div class="readout-label">Average time on site</div>
            <div class="readout-value" style="font-size: 2rem;">{formatTime(data.avgTimeMs)}</div>
            <div class="readout-caption">across {fmt(data.sessionCountWithTime)} completed sessions</div>
          </div>

          {/* Simulations run - headline */}
          <div class="readout-card mb-2" style="padding: 1.5rem;">
            <div class="readout-label">Simulations run</div>
            <div class="readout-value" style="font-size: 2rem;">{fmt(totalSimRuns)}</div>
            <div class="readout-caption">
              {fmt(data.anySimSessions)} distinct people ran a simulation, averaging {avgRunsPerRunner} runs per person
            </div>
          </div>

          {/* By section breakdown */}
          <div class="mb-4 pl-4 border-l-2 border-ink/10" style="margin-left: 0.5rem;">
            <div class="readout-label mb-3">By section</div>

            <div class="mb-3">
              <div class="text-sm font-medium">Section 1 - The opening question</div>
              <div class="text-sm text-ink/50">{fmt(data.s1Sessions)} people locked in a bet</div>
            </div>

            <div class="mb-3">
              <div class="text-sm font-medium">Section 2 - Edge calculator</div>
              <div class="text-sm text-ink/50">{fmt(data.s2Sessions)} people clicked a preset scenario</div>
            </div>

            <div class="mb-3">
              <div class="text-sm font-medium">Section 3 - Main simulator</div>
              <div class="text-sm text-ink/50">{fmt(data.s3Total)} total runs across {fmt(data.s3Sessions)} distinct people</div>
              <div class="text-sm text-ink/50">averaging {s3Avg} runs per person</div>
            </div>

            <div class="mb-3">
              <div class="text-sm font-medium">Section 4 - Half Kelly explainer</div>
              <div class="text-sm text-ink/50">{fmt(data.s4Sessions)} people engaged with the slider</div>
            </div>

            <div>
              <div class="text-sm font-medium">Section 5 - Gambler's ruin</div>
              <div class="text-sm text-ink/50">{fmt(data.s5Total)} total runs across {fmt(data.s5Sessions)} distinct people</div>
              <div class="text-sm text-ink/50">averaging {s5Avg} runs per person</div>
            </div>
          </div>

          {/* Scrolled to the bottom */}
          <div class="readout-card mb-4" style="padding: 1.5rem;">
            <div class="readout-label">Scrolled to the bottom</div>
            <div class="readout-value" style="font-size: 2rem;">{scrollPct}%</div>
            <div class="readout-caption">
              {fmt(data.scrolledToBottom)} of {fmt(data.sessionCountWithTime)} visitors made it all the way to the end
            </div>
          </div>

          <p class="text-sm italic text-ink/30 mt-8 text-center">Data current as of {now}</p>
        </div>
      )}

      <div class="mt-12 text-center">
        <a href="/" class="text-gold text-sm" style="text-decoration: none;">&larr; back to the article</a>
      </div>
    </div>
  </main>
</Base>
